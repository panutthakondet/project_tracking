@model IEnumerable<ProjectTracking.Models.TestTemplateGroup>

<style>
    .group-table thead th {
        background-color: #6f42c1 !important; /* purple */
        color: #ffffff;
        text-align: center;
        vertical-align: middle;
    }

    .text-center-col {
        text-align: center;
        vertical-align: middle;
    }
</style>

<h2>Template Groups</h2>

<a asp-action="Create" class="btn btn-success mb-3">+ Add Group</a>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">ไม่พบ Template Group</div>
    return;
}

<table class="table table-bordered group-table">
    <thead>
        <tr>
            <th width="50"></th>
            <th width="100" class="text-center-col">Order</th>
            <th>Group Name</th>
            <th class="text-center-col">Created</th>
            <th width="100" class="text-center-col">Edit</th>
            <th width="150" class="text-center-col">Delete</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var g in Model)
    {
        <tr data-id="@g.group_id">
            <td class="text-center-col" style="cursor:move;">☰</td>
            <td class="text-center-col">@g.sort_order</td>
            <td>@g.group_name</td>
            <td class="text-center-col">@g.created_at.ToString("dd/MM/yyyy")</td>
            <td class="text-center-col">
                <a asp-action="Edit"
                   asp-route-id="@g.group_id"
                   class="btn btn-sm btn-warning">Edit</a>
            </td>
            <td class="text-center-col">
                <form asp-action="Delete"
                      asp-route-id="@g.group_id"
                      method="post"
                      style="display:inline;"
                      onsubmit="return confirm('Delete this group?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
    var tbody = document.querySelector(".group-table tbody");

    new Sortable(tbody, {
        handle: "td",
        animation: 150,
        onEnd: function () {
            var order = [];
            document.querySelectorAll(".group-table tbody tr").forEach((row, index) => {
                order.push({
                    id: row.getAttribute("data-id"),
                    sort: index + 1
                });
            });

            fetch('/TestTemplateGroups/UpdateSort', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(order)
            });
        }
    });
</script>