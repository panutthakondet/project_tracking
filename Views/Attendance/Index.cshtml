<h2 style="text-align:center;margin-bottom:20px;">ระบบเช็คชื่อเข้างาน และ ออกงาน</h2>

<form id="antiForgeryForm" method="post">
    @Html.AntiForgeryToken()
</form>

<div style="display:flex;justify-content:center;gap:15px;">
    <button id="btnCheckIn" onclick="check('checkin')" style="padding:12px 28px;border:none;border-radius:10px;background:#4CAF50;color:white;font-weight:bold;cursor:pointer;font-size:16px;">
        📍 เช็คเข้างาน
    </button>

    <button id="btnCheckOut" onclick="check('checkout')" style="padding:12px 28px;border:none;border-radius:10px;background:#f44336;color:white;font-weight:bold;cursor:pointer;font-size:16px;">
        📍 เช็คออกงาน
    </button>
</div>

<div id="distanceBox" style="margin-top:10px;font-weight:bold;color:#333;"></div>
<div id="map" style="height:350px;margin-top:15px;border-radius:10px;overflow:hidden;border:2px solid #ddd;">
    <iframe id="mapFrame" width="100%" height="100%" style="border:0;" loading="lazy"></iframe>
</div>

<script>

function loadCurrentLocation() {
    if (!navigator.geolocation) return;

    navigator.geolocation.getCurrentPosition(function (pos) {

        let lat = pos.coords.latitude;
        let lng = pos.coords.longitude;

        // แสดง Google Map
        let url = `https://www.google.com/maps?q=${lat},${lng}&z=16&output=embed`;
        document.getElementById("mapFrame").src = url;

    });
}

function check(type) {
    if (!navigator.geolocation) {
        alert("อุปกรณ์นี้ไม่รองรับ GPS");
        return;
    }

    navigator.geolocation.getCurrentPosition(
        function (pos) {

            let lat = pos.coords.latitude;
            let lng = pos.coords.longitude;

            // ไม่อัปเดต map ตอนกดเช็คเวลา (map ใช้แสดงอย่างเดียว)

            fetch('/Attendance/Save', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({
                    lat: pos.coords.latitude,
                    lng: pos.coords.longitude,
                    type: type
                })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {

                    if (res.distanceKm !== undefined && res.distanceKm !== null) {
                        let distance = res.distanceKm;
                        let color = "green";

                        if (distance > 8) {
                            color = "red";
                        } else if (distance > 3) {
                            color = "orange";
                        }

                        document.getElementById("distanceBox").innerHTML =
                            "📍 ระยะจากจุดเข้างาน: <span style='color:" + color + ";font-weight:bold;'>" 
                            + distance.toFixed(2) + " km</span>";
                    }

                    if (res.type === "checkin") {
                        alert("✅ เข้างานเรียบร้อย");

                        let btn = document.getElementById("btnCheckIn");
                        btn.disabled = true;
                        btn.style.opacity = "0.5";
                        btn.style.cursor = "not-allowed";

                    } else if (res.type === "checkout") {
                        alert("✅ ออกงานเรียบร้อย");

                        let btn = document.getElementById("btnCheckOut");
                        btn.disabled = true;
                        btn.style.opacity = "0.5";
                        btn.style.cursor = "not-allowed";
                    }

                    // location.reload();

                    // Smooth update message instead of reload
                    setTimeout(() => {
                        document.getElementById("distanceBox").style.opacity = "1";
                    }, 100);

                } else {
                    alert("❌ " + res.message);
                }
            })
            .catch(() => {
                alert("❌ เกิดข้อผิดพลาด");
            });

        },
        function (error) {
            console.log("GPS ERROR:", error);

            let msg = "";

            switch (error.code) {
                case error.PERMISSION_DENIED:
                    msg = "❌ คุณยังไม่ได้อนุญาตการใช้ตำแหน่ง";
                    break;
                case error.POSITION_UNAVAILABLE:
                    msg = "❌ ไม่สามารถระบุตำแหน่งได้";
                    break;
                case error.TIMEOUT:
                    msg = "❌ ใช้เวลานานเกินไปในการดึงตำแหน่ง";
                    break;
                default:
                    msg = "❌ ไม่สามารถใช้งาน GPS ได้";
                    break;
            }

            alert(msg + "\n\n📍 กรุณาเปิด Location / GPS ก่อนใช้งาน\nระบบจะไม่สามารถบันทึกได้");

            return; // หยุดการทำงาน
        },
        {
            enableHighAccuracy: false,
            timeout: 20000,
            maximumAge: 60000
        }
    );
}
</script>
<script>
window.onload = function () {
    loadCurrentLocation();
};
</script>