@model IEnumerable<ProjectTracking.Models.TestScenarioTemplate>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@{
    var groups = ViewBag.Groups as IEnumerable<ProjectTracking.Models.TestTemplateGroup>
                 ?? Enumerable.Empty<ProjectTracking.Models.TestTemplateGroup>();
}
@{
    int? selectedGroupId = null;
    if (ViewBag.SelectedGroupId != null)
    {
        selectedGroupId = (int)ViewBag.SelectedGroupId;
    }
}

<style>
    /* Colored table header */
    .template-table thead th {
        background-color: #198754 !important; /* green */
        color: #ffffff;
        text-align: center;
        vertical-align: middle;
    }

    /* Center specific columns */
    .text-center-col {
        text-align: center;
        vertical-align: middle;
    }

    /* Make wide tables scroll horizontally without breaking the page */
    .template-table {
        min-width: 1400px; /* forces horizontal scroll inside the wrapper */
    }

    /* Improve readability for long text */
    .template-table td {
        vertical-align: top;
    }
</style>

<h2>Scenario Templates</h2>

<div class="row mb-3">
    <div class="col-md-4">
        <label class="form-label">Filter by Group</label>
        <select id="templateFilter" class="form-select" onchange="filterTemplates()">
            <option value="">-- Show All --</option>
            @foreach (var g in groups)
            {
                if (selectedGroupId.HasValue && selectedGroupId.Value == g.group_id)
                {
                    <option value="@g.group_id" selected>@g.group_name</option>
                }
                else
                {
                    <option value="@g.group_id">@g.group_name</option>
                }
            }
        </select>
    </div>
</div>

<a id="addTemplateBtn" href="#" class="btn btn-success mb-3">+ Add Template</a>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">ไม่พบ Scenario Template</div>
}
else
{
    <div class="table-responsive">
    <table class="table table-bordered table-striped table-sm align-middle template-table">
    <thead>
        <tr>
            <th style="min-width:60px;">#</th>
            <th style="min-width:180px;">Template Group</th>
            <th style="min-width:180px;">Title</th>
            <th style="min-width:220px;">Precondition</th>
            <th style="min-width:320px;">Steps</th>
            <th style="min-width:220px;">Expected Result</th>
            <th style="min-width:90px;" class="text-center-col">Priority</th>
            <th style="min-width:90px;" class="text-center-col">Status</th>
            <th style="min-width:90px;" class="text-center-col">Active</th>
            <th style="min-width:190px;" class="text-center-col">Actions</th>
        </tr>
    </thead>
    <tbody>
    @{ 
        int currentGroupId = int.MinValue;
        int groupRowNo = 0;
    }
    @foreach (var item in Model.OrderBy(x => x.group_id ?? 0).ThenBy(x => x.template_id))
    {
        var gid = item.group_id ?? 0;
        if (gid != currentGroupId)
        {
            currentGroupId = gid;
            groupRowNo = 0;
        }
        groupRowNo++;

        <tr data-gid="@gid">
            <td>@groupRowNo</td>
            <td>@(item.Group != null ? item.Group.group_name : "Ungrouped")</td>
            <td>@item.title</td>
            <td>@item.precondition</td>
            <td style="white-space: pre-line;">@item.steps</td>
            <td>@item.expected_result</td>
            <td class="text-center-col">@item.priority_default</td>
            <td class="text-center-col">@item.status_default</td>
            <td class="text-center-col">
                @if (item.is_active)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactive</span>
                }
            </td>
            <td class="text-center-col">
                <a asp-action="Edit"
                   asp-route-id="@item.template_id"
                   class="btn btn-sm btn-warning">Edit</a>

                <form asp-action="ToggleActive"
                      asp-route-id="@item.template_id"
                      method="post"
                      style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-info">Toggle</button>
                </form>

                <form asp-action="Delete"
                      asp-route-id="@item.template_id"
                      method="post"
                      style="display:inline;"
                      onsubmit="return confirm('Delete this template?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
    </table>
    </div>
}

<script>
    function filterTemplates() {
        var selected = document.getElementById("templateFilter").value;
        var rows = document.querySelectorAll("tbody tr");

        rows.forEach(function(row) {
            var gid = row.getAttribute("data-gid");
            if (!selected || gid === selected) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }

    document.addEventListener("DOMContentLoaded", function () {
        var serverPreset = "@(selectedGroupId?.ToString() ?? "")";
        var storedPreset = localStorage.getItem('ScenarioTemplates.SelectedGroupId') || "";
        var preset = serverPreset || storedPreset;

        var ddl = document.getElementById("templateFilter");
        if (ddl && preset) {
            ddl.value = preset;
        }

        // Apply filtering based on current selection (server preset or stored)
        if (ddl && ddl.value) {
            filterTemplates();
        }

        // Remember selection whenever user changes the dropdown
        if (ddl) {
            ddl.addEventListener('change', function () {
                localStorage.setItem('ScenarioTemplates.SelectedGroupId', ddl.value || "");
            });
        }

        var btn = document.getElementById("addTemplateBtn");
        if (!btn) return;

        btn.addEventListener("click", function (e) {
            e.preventDefault();

            var selected = document.getElementById("templateFilter").value;
            if (!selected) {
                alert("กรุณาเลือก Template Group ก่อน");
                return;
            }

            localStorage.setItem('ScenarioTemplates.SelectedGroupId', selected);
            window.location.href = "/TestScenarioTemplates/Create?groupId=" + encodeURIComponent(selected);
        });
    });
</script>