@model IEnumerable<ProjectTracking.Models.ProjectIssue>

@{
    ViewData["Title"] = "แก้ไขสถานะปัญหาโครงการ";
    var selectedProject = ViewBag.SelectedProject as ProjectTracking.Models.Project;
    var selectedEmp = ViewBag.SelectedEmp as string;
    var empList = ViewBag.EmpList as IEnumerable<string> ?? Enumerable.Empty<string>();
    var projects = ViewBag.Projects as IEnumerable<ProjectTracking.Models.Project> ?? Enumerable.Empty<ProjectTracking.Models.Project>();
}

<style>
.table-wrapper{
    overflow-x:auto;
}
.issue-table{
    min-width:1200px;
}
.col-id{ width:70px; text-align:center; }
.col-issue{ min-width:300px; }
.col-owner{ width:160px; text-align:center; }
.col-status{ width:150px; text-align:center; }
.col-priority{ width:120px; text-align:center; }
.col-action{ width:120px; text-align:center; white-space:nowrap; }
</style>

<div class="mb-3">
    <h2 class="fw-bold mb-0">👨‍💻 แก้ไขสถานะปัญหาโครงการ</h2>
    <small class="text-muted">โปรแกรมเมอร์แก้ Dev Status เท่านั้น</small>
</div>

<form method="get" id="filterForm" class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label fw-semibold">📁 Project</label>
        <select id="projectSelect" name="projectId" class="form-select" onchange="document.getElementById('filterForm').submit()">
            <option value="">-- Select Project --</option>
            @foreach (var p in projects
                                .OrderBy(x => x.EndDate ?? DateTime.MaxValue))
            {
                <option value="@p.ProjectId" selected="@(selectedProject?.ProjectId == p.ProjectId)">@p.ProjectName</option>
            }
        </select>
    </div>

    @if (selectedProject != null)
    {
        <div class="col-md-4">
            <label class="form-label fw-semibold">👤 Owner</label>
            <select name="empName" class="form-select" onchange="document.getElementById('filterForm').submit()">
                <option value="">-- All --</option>
                @foreach (var emp in empList)
                {
                    <option value="@emp" selected="@(emp == selectedEmp)">@emp</option>
                }
            </select>
        </div>
    }
</form>

@if (selectedProject == null)
{
    <div class="alert alert-info">⬆ กรุณาเลือก Project เพื่อดูรายการ Issue</div>
}
else
{
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">ไม่พบรายการ Issue</div>
        return;
    }
    <div class="table-wrapper">
        <table class="table table-bordered table-hover align-middle issue-table">
            <thead class="table-dark text-center">
                <tr>
                    <th class="col-id">No.</th>
                    <th class="col-issue">Issue</th>
                    <th class="col-owner">Owner</th>
                    <th class="col-status">Status</th>
                    <th class="col-status">Dev Status</th>
                    <th class="col-priority">Priority</th>
                    <th class="col-action">Dev</th>
                </tr>
            </thead>

            <tbody>
            @{ var row = 1; }
            @foreach (var i in Model)
            {
                var urgent = i.IssuePriority == "URGENT";

                string statusClass =
                    i.IssueStatus == "OPEN" ? "bg-warning text-dark" :
                    i.IssueStatus == "WIP" ? "bg-info text-dark" :
                    i.IssueStatus == "FIXED" ? "bg-success" :
                    i.IssueStatus == "PASS" ? "bg-primary" :
                    i.IssueStatus == "FAIL" ? "bg-danger" :
                    i.IssueStatus == "REJECT" ? "bg-dark" :
                    "bg-secondary";

                <tr class="@(urgent ? "table-danger" : "")">
                    <td class="col-id fw-semibold">@row</td>

                    <td class="col-issue">
                        <div class="fw-semibold">@i.IssueName</div>
                        <small class="text-muted">📅 @i.CreatedAt.ToString("dd/MM/yyyy")</small>
                    </td>

                    <td class="col-owner"><span class="badge bg-light text-dark border">@(i.Employee?.EmpName ?? "-")</span></td>
                    <td class="col-status"><span class="badge @statusClass">@i.IssueStatus</span></td>
                    <td class="col-status">
                        <span class="badge 
                            @(i.DevStatus == "TODO" ? "bg-secondary" :
                              i.DevStatus == "DOING" ? "bg-info text-dark" :
                              i.DevStatus == "FIXED" ? "bg-success" :
                              i.DevStatus == "BLOCK" ? "bg-danger" : "bg-dark")">
                            @i.DevStatus
                        </span>
                    </td>
                    <td class="col-priority"><span class="badge @(urgent ? "bg-danger" : "bg-secondary")">@(urgent ? "🔥 URGENT" : "NORMAL")</span></td>

                    <td class="col-action">
                        <div class="d-inline-flex gap-1">
                            <a asp-controller="ProjectIssues"
                               asp-action="DevDetails"
                               asp-route-id="@i.IssueId"
                               asp-route-projectId="@selectedProject!.ProjectId"
                               class="btn btn-sm btn-outline-secondary">👁 View</a>
                            <a asp-action="DevEdit" asp-route-id="@i.IssueId" asp-route-projectId="@selectedProject?.ProjectId" class="btn btn-sm btn-warning">✏️ Edit</a>
                        </div>
                    </td>
                </tr>
                row++;
            }
            </tbody>
        </table>
    </div>
}