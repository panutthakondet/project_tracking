@{
    ViewData["Title"] = "Employee Workload";
}


<h2>🔥 สถานะภาระงานพนักงาน</h2>
<div class="legend">
    <span><i class="legend-box project"></i> Period Date</span>
    <span><i class="legend-box plan"></i> Plan Date</span>
    <span><i class="legend-box actual"></i> Actual Date</span>
</div>

<div class="filter-bar">

    <div class="filter-group">
        <label>From Year</label>
        <select id="yearFrom" onchange="reloadTimeline()">
            @{
                var currentYear = DateTime.Now.Year;
                for(int y = currentYear - 5; y <= currentYear + 1; y++)
                {
                    <option value="@y" selected="@(y == currentYear)">@y</option>
                }
            }
        </select>
    </div>

    <div class="filter-group">
        <label>To Year</label>
        <select id="yearTo" onchange="reloadTimeline()">
            @{
                for(int y = currentYear - 5; y <= currentYear + 1; y++)
                {
                    <option value="@y" selected="@(y == currentYear)">@y</option>
                }
            }
        </select>
    </div>

    <div class="filter-group employee-group">
        <label>Select Employee</label>
        <select id="employeeSelect" onchange="renderTimeline()">
            <option value="ALL">All Employees</option>
        </select>
    </div>

</div>

<div class="timeline-wrapper">
    <div id="timeline-container"></div>
</div>

<style>

/* ===== FILTER BAR ===== */
.filter-bar{
    display:flex;
    gap:24px;
    align-items:flex-end;
    margin-bottom:12px;
    flex-wrap:wrap;
}

.filter-group{
    display:flex;
    flex-direction:column;
    gap:6px;
    min-width:120px;
}

.filter-group label{
    font-size:12px;
    font-weight:600;
    color:#6b7280;
}

.filter-group select{
    padding:6px 10px;
    border-radius:6px;
    border:1px solid #d1d5db;
    font-size:14px;
    background:#f9fafb;
    transition:all 0.2s ease;
}

.filter-group select:focus{
    outline:none;
    border-color:#3b82f6;
    box-shadow:0 0 0 2px rgba(59,130,246,0.2);
    background:white;
}

.employee-group{
    min-width:220px;
}

.timeline-wrapper{
    overflow:auto;
    height:75vh;
    position:relative;
    background:white;
}

/* GRID */
.grid{
    display:grid;
    font-size:13px;
    min-width:max-content;
}

/* ================= HEADER FREEZE ================= */

/* เดือน */
.header-month{
    text-align:center;
    font-weight:bold;
    background:#111827;
    color:white;
    padding:6px 0;

    position:sticky;
    top:0;
    z-index:20;
}

/* สัปดาห์ */
.header-week{
    text-align:center;
    font-size:11px;
    background:#f3f4f6;

    position:sticky;
    top:34px;      /* ความสูง header เดือน */
    z-index:20;
    border-bottom:2px solid #d1d5db;
}

/* มุมซ้ายบน */
.grid > div:first-child{
    position:sticky;
    left:0;
    top:0;
    z-index:25;
    background:#111827;
}

/* ================= FREEZE COLUMN ================= */

.employee-title{
    font-weight:600;
    font-size:16px;  
    background:#f9fafb;
    padding:8px;
    border-top:2px solid #d1d5db;

    position:sticky;
    left:0;
    z-index:15;
}

.project-name{
    padding-left:25px;
    font-size:11px;
    color:#374151;
    background:white;

    position:sticky;
    left:0;
    z-index:14;
}

.project-row-hover {
    background: #dbeafe; /* ฟ้าอ่อนแบบทึบ */
}

.project-name.project-row-hover {
    background: #bfdbfe; /* เข้มขึ้นเล็กน้อยให้เด่น */
}

/* เส้นแบ่ง */
.employee-title::after,
.project-name::after{
    content:"";
    position:absolute;
    right:0;
    top:0;
    width:2px;
    height:100%;
    background:#d1d5db;
}

/* CELLS */
    .cell{
        height:44px;
        border:1px solid #e5e7eb;
        display:flex;
        flex-direction:column;
        justify-content:center;
        padding:0; /* เอาช่องว่างออก */
        gap:2px;   /* เว้นเล็กน้อยระหว่าง 3 เส้น */
    }



/* ====== BAR STYLES FOR CELLS ====== */
.bar{
    height:12px;
    border-radius:0; /* ทำให้เส้นต่อกันไม่เว้า */
    width:100%;
}
.cell:hover .bar{
    filter:brightness(1.1);
}
.bar.project{ background:#60a5fa; }  /* ฟ้าอ่อน */
.bar.plan{ background:#fde68a; }     /* เหลืองอ่อน */
.bar.actual{ background:#86efac; }   /* เขียวอ่อน */


/* ===== LEGEND ===== */
.legend{
    display:flex;
    gap:20px;
    margin-bottom:10px;
    font-size:13px;
    align-items:center;
}

.legend-box{
    display:inline-block;
    width:14px;
    height:14px;
    margin-right:6px;
    border-radius:3px;
}

.legend-box.project{ background:#60a5fa; }
.legend-box.plan{ background:#fde68a; }
.legend-box.actual{ background:#86efac; }
</style>

<script>

let globalData = [];

async function loadTimeline(yearFrom, yearTo){

    const res = await fetch(`/Dashboard/GetWorkloadData?yearFrom=${yearFrom}&yearTo=${yearTo}`);
    globalData = await res.json();

    populateEmployeeDropdown(globalData);
    renderTimeline();
}

function populateEmployeeDropdown(data){

    const dropdown = document.getElementById("employeeSelect");

    const employees = [...new Set(data.map(d=>d.Emp_Name || d.emp_Name))].sort();

    dropdown.innerHTML = `<option value="ALL">All Employees</option>`;

    employees.forEach(emp=>{
        dropdown.innerHTML += `<option value="${emp}">${emp}</option>`;
    });
}

function renderTimeline(){

    const container = document.getElementById('timeline-container');
    const selectedEmp = document.getElementById("employeeSelect").value;

    const yearFrom = parseInt(document.getElementById("yearFrom").value);
    const yearTo   = parseInt(document.getElementById("yearTo").value);

    const monthNames = [
        "มกราคม","กุมภาพันธ์","มีนาคม","เมษายน","พฤษภาคม","มิถุนายน",
        "กรกฎาคม","สิงหาคม","กันยายน","ตุลาคม","พฤศจิกายน","ธันวาคม"
    ];

    let months = [];

    for(let y = yearFrom; y <= yearTo; y++){
        for(let m = 1; m <= 12; m++){
            months.push({ year: y, month: m, name: `${monthNames[m-1]} ${y}` });
        }
    }

    const totalWeeks = months.length * 4;

    let html = `<div class="grid" style="grid-template-columns:260px repeat(${totalWeeks},28px);">`;

    /* ========= HEADER ========= */

    html += `<div></div>`;

    // เดือน (เดือนละ 4 ช่อง)
    months.forEach(m=>{
        html += `<div class="header-month" style="grid-column: span 4;">${m.name}</div>`;
    });

    html += `<div></div>`;

    // W1 W2 W3 W4 ต่อเดือน
    months.forEach(()=>{
        for(let w=1; w<=4; w++){
            html += `<div class="header-week">W${w}</div>`;
        }
    });

    /* ========= FILTER EMPLOYEE ========= */

    let employees = [...new Set(globalData.map(d=>d.Emp_Name || d.emp_Name))].sort();

    if(selectedEmp !== "ALL"){
        employees = employees.filter(e=>e===selectedEmp);
    }

    employees.forEach(emp=>{

        const empData = globalData.filter(d=>(d.Emp_Name || d.emp_Name)===emp);

        let projectSet = new Set();
        empData.forEach(d=>{
            const pname = d.Project_Name || d.project_Name;
            if(pname){
                projectSet.add(pname);
            }
        });

        const projects = [...projectSet];

        /* ==== EMPLOYEE TITLE ==== */
        html += `<div class="employee-title">${emp}</div>`;
        for(let i=0;i<totalWeeks;i++) html+=`<div></div>`;

        /* ==== PROJECT ROWS ==== */
        projects.forEach((project,index)=>{

            const color = `p${(index%5)+1}`;

            html += `<div class="project-name" data-row-key="${emp}__${index}">↳ ${project}</div>`;

            for(let w=1; w<=totalWeeks; w++){

                const monthIndex = Math.floor((w-1)/4);
                const weekInMonth = ((w-1)%4)+1;

                const currentMonth = months[monthIndex];
                const weekStart = new Date(currentMonth.year, currentMonth.month - 1, (weekInMonth - 1) * 7 + 1);
                const weekEnd   = new Date(currentMonth.year, currentMonth.month - 1, (weekInMonth * 7));

                const projectList = empData.filter(x =>
                    (x.Project_Name || x.project_Name) === project
                );

                const hasProject = projectList.some(x => {
                    const start = new Date(x.Project_Start || x.project_Start);
                    const end   = new Date(x.Project_End || x.project_End);
                    return start <= weekEnd && end >= weekStart;
                });

                const hasPlan = projectList.some(x => {
                    const start = new Date(x.Plan_Start || x.plan_Start);
                    const end   = new Date(x.Plan_End || x.plan_End);
                    return start <= weekEnd && end >= weekStart;
                });

                const hasActual = projectList.some(x => {
                    const start = new Date(x.Actual_Start || x.actual_Start);
                    const end   = new Date(x.Actual_End || x.actual_End || x.actual_Start);
                    return start <= weekEnd && end >= weekStart;
                });

                const isDelay = projectList.some(x =>
                    (x.Actual_End || x.actual_End) && (x.Plan_End || x.plan_End) && new Date((x.Actual_End || x.actual_End)) > new Date((x.Plan_End || x.plan_End))
                );

                html += `
                    <div class="cell" data-row-key="${emp}__${index}" title="${project}">
                        <div class="bar project" style="opacity:${hasProject ? 1 : 0}"></div>
                        <div class="bar plan" style="opacity:${hasPlan ? 1 : 0}"></div>
                        <div class="bar ${isDelay ? 'delay' : 'actual'}" style="opacity:${hasActual ? 1 : 0}"></div>
                    </div>
                `;
            }

        });

    });

    html += `</div>`;
    container.innerHTML = html;

    const rowElements = container.querySelectorAll('[data-row-key]');
    rowElements.forEach(el => {
        el.addEventListener('mouseenter', function () {
            const key = this.getAttribute('data-row-key');
            container.querySelectorAll(`[data-row-key="${key}"]`).forEach(x => x.classList.add('project-row-hover'));
        });
        el.addEventListener('mouseleave', function () {
            const key = this.getAttribute('data-row-key');
            container.querySelectorAll(`[data-row-key="${key}"]`).forEach(x => x.classList.remove('project-row-hover'));
        });
    });
}

function reloadTimeline(){
    const yearFrom = document.getElementById("yearFrom").value;
    const yearTo = document.getElementById("yearTo").value;

    if(parseInt(yearFrom) > parseInt(yearTo)){
        alert("From Year must be less than or equal to To Year");
        return;
    }

    loadTimeline(yearFrom, yearTo);
}

document.addEventListener("DOMContentLoaded", function(){
    const yearFrom = document.getElementById("yearFrom").value;
    const yearTo = document.getElementById("yearTo").value;
    loadTimeline(yearFrom, yearTo);
});

</script>