@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Follow-up DONE (Waiting ACK)";
    var th = new System.Globalization.CultureInfo("th-TH");
    int i = 1;
    var owners = Model.Select(x => (string)x.Owner).Distinct().OrderBy(x => x).ToList();
}

<div class="container-fluid mt-4">

    <h3 class="mb-3">
        ✅ งานที่ Owner ทำเสร็จแล้ว
    </h3>

    <div class="mb-3" style="max-width:300px;">
        <label class="form-label fw-bold">Filter Owner</label>
        <select id="ownerFilter" class="form-select" onchange="filterOwner()">
            <option value="">-- All Owner --</option>
            @foreach (var o in owners)
            {
                <option value="@o">@o</option>
            }
        </select>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">

            <thead class="table-dark text-center">
                <tr>
                    <th style="width:60px">No.</th>
                    <th>Project</th>
                    <th style="width:200px">Task</th>
                    <th style="width:100px">Partner</th>
                    <th style="width:180px">Owner</th>
                    <th style="width:150px">Follow-up Date</th>
                    <th style="width:120px">State</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {

                    var projectId = item.ProjectId;
                    var targetUrl = projectId != null ? Url.Action("Index", "Followups", new { projectId = projectId }) : null;

                    string rowClass = "table-success";

                    <tr class="@rowClass" data-owner="@item.Owner"
                        style="cursor:@(targetUrl != null ? "pointer" : "default")"
                        onclick="@(targetUrl != null ? $"window.location.href='{targetUrl}'" : "")">

                        <td class="text-center">@i</td>

                        <td>
                            @item.Project
                        </td>

                        <td>
                            @item.TaskTitle
                        </td>

                        <td class="text-center">
                            @item.PartnerName
                        </td>

                        <td>
                            @item.Owner
                        </td>

                        <td class="text-center">
                            @(((DateTime)item.NextFollowupDate).ToString("dd MMM yyyy", th))
                        </td>

                        <td class="text-center fw-bold">
                            <span class="badge bg-success">DONE</span>
                        </td>

                    </tr>

                    i++;
                }

            </tbody>

        </table>
    </div>

<script>
function filterOwner() {
    const selected = document.getElementById("ownerFilter").value.toLowerCase();
    const rows = document.querySelectorAll("tbody tr");

    rows.forEach(r => {
        const owner = (r.getAttribute("data-owner") || "").toLowerCase();

        if (selected === "" || owner === selected) {
            r.style.display = "";
        } else {
            r.style.display = "none";
        }
    });
}
</script>

</div>