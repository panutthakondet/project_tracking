

@model List<ProjectTracking.Models.ProjectFollowupLog>

@{
    ViewData["Title"] = "Follow-up History";
    var followup = ViewBag.Followup;
}

<h2>Follow-up History</h2>

@if (followup != null)
{
    <div class="mb-3">
        <strong>Task:</strong> @followup.TaskTitle
    </div>
}

<table class="table table-bordered table-striped">
    <thead class="table-dark text-center">
        <tr>
            <th style="width:80px;">No.</th>
            <th style="width:150px;">Contact Type</th>
            <th>Note</th>
            <th style="width:180px;">Contact Date</th>
            <th style="width:180px;">Next Follow-up</th>
        </tr>
    </thead>
    <tbody>
        @{
            int no = 1;
        }

        @foreach (var log in Model)
        {
            <tr>
                <td class="text-center">@no</td>
                <td class="text-center">@log.ContactType</td>
                <td>@log.Note</td>
                <td class="text-center">
                    @log.ContactDate.ToString("dd/MM/yyyy HH:mm")
                </td>
                <td class="text-center">
                    @(log.NextFollowupDate?.ToString("dd/MM/yyyy"))
                </td>
            </tr>

            no++;
        }

        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    No history found
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Index"
       asp-route-projectId="@followup?.ProjectId"
       class="btn btn-secondary">
        Back
    </a>
</div>