@using Microsoft.AspNetCore.Http
@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Follow-up Dashboard";
    var th = new System.Globalization.CultureInfo("th-TH");
    int i = 1;
    var owners = Model.Select(x => (string)x.Owner).Distinct().OrderBy(x => x).ToList();

    Func<string, bool> HasMenu = key =>
    {
        var menus = Context.Session.GetString("Menus");
        if (string.IsNullOrEmpty(menus)) return false;
        return menus.Split(',').Any(m => m.Trim().Equals(key, StringComparison.OrdinalIgnoreCase));
    };
}

@if (!HasMenu("Followups.Dashboard"))
{
    <div class="container mt-4">
        <div class="alert alert-danger fw-bold">
            ❌ ไม่มีสิทธิ์เข้าหน้านี้
        </div>
        <a class="btn btn-secondary" href="/Followups">← กลับ</a>
    </div>
    return;
}

<div class="container-fluid mt-4">

    <h3 class="mb-3">
        📌 งานติดตาม (Follow-up Dashboard)
    </h3>

    <div class="mb-3" style="max-width:300px;">
        <label class="form-label fw-bold">Filter Owner</label>
        <select id="ownerFilter" class="form-select" onchange="filterOwner()">
            <option value="">-- All Owner --</option>
            @foreach (var o in owners)
            {
                <option value="@o">@o</option>
            }
        </select>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">

            <thead class="table-dark text-center">
                <tr>
                    <th style="width:60px">No.</th>
                    <th>Project</th>
                    <th style="width:200px">Task</th>
                    <th style="width:100px">Partner</th>
                    <th style="width:180px">Owner</th>
                    <th style="width:150px">Follow-up Date</th>
                    <th style="width:120px">Status</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {

                    var projectId = item.ProjectId;
                    var targetUrl = projectId != null ? Url.Action("Index", "Followups", new { projectId = projectId }) : null;

                    string rowClass = "";

                    if (item.Status == "Overdue")
                    {
                        rowClass = "table-danger";
                    }
                    else if (item.Status == "Today")
                    {
                        rowClass = "table-warning";
                    }
                    else
                    {
                        rowClass = "table-success";
                    }

                    <tr class="@rowClass" data-owner="@item.Owner"
                        style="cursor:@(targetUrl != null && HasMenu("Followups.Index") ? "pointer" : "default")"
                        onclick="@(targetUrl != null && HasMenu("Followups.Index") ? $"window.location.href='{targetUrl}'" : "")">

                        <td class="text-center">@i</td>

                        <td>
                            @item.Project
                        </td>

                        <td>
                            @item.TaskTitle
                        </td>

                        <td class="text-center">
                            @item.PartnerName
                        </td>

                        <td>
                            @item.Owner
                        </td>

                        <td class="text-center">
                            @(((DateTime)item.NextFollowupDate).ToString("dd MMM yyyy", th))
                        </td>

                        <td class="text-center fw-bold">
                            @item.Status
                        </td>

                    </tr>

                    i++;
                }

            </tbody>

        </table>
    </div>

</div>
<script>
function filterOwner() {
    const selected = document.getElementById("ownerFilter").value.toLowerCase();
    const rows = document.querySelectorAll("tbody tr");

    rows.forEach(r => {
        const owner = (r.getAttribute("data-owner") || "").toLowerCase();

        if (selected === "" || owner === selected) {
            r.style.display = "";
        } else {
            r.style.display = "none";
        }
    });
}
</script>