@model IEnumerable<ProjectTracking.Models.ProjectFollowup>

<h2>งานที่ต้องติดตาม</h2>
@{
    var isAdmin = Context.Session.GetString("Role") == "ADMIN";
}


<form method="get" action="/Followups/Index" class="mb-2">
    <select name="projectId"
            class="form-select"
            style="max-width:300px;"
            onchange="this.form.submit()"
            asp-items="@(new SelectList(ViewBag.Projects, "ProjectId", "ProjectName", Context.Request.Query["projectId"]))">
        <option value="">-- เลือก Project --</option>
    </select>
</form>

@if (string.IsNullOrEmpty(Context.Request.Query["projectId"]))
{
    <div class="alert alert-secondary mt-3 p-3">
        ⬆ กรุณาเลือก Project ก่อน
    </div>
}

<div class="mb-3">
@if(isAdmin)
{
    <a href="/Followups/Create?projectId=@Context.Request.Query["projectId"]" class="btn btn-primary">
        + สร้างงานติดตาม
    </a>
}
else
{
    <button class="btn btn-primary" disabled title="User ไม่มีสิทธิ์สร้าง">
        + สร้างงานติดตาม
    </button>
}
</div>

@if (!string.IsNullOrEmpty(Context.Request.Query["projectId"]))
{
    <div class="mb-2">
        <strong>จำนวน Follow-up:</strong> @Model.Count()
    </div>

    <table class="table table-bordered">
    <thead>
        <tr>
            <th style="width:60px; text-align:center;">No.</th>
            <th style="text-align:center;">Task</th>
            <th style="text-align:center;">Partner</th>
            <th style="text-align:center;">Owner</th>
            <th style="text-align:center;">Next Follow-up</th>
            <th style="text-align:center;">Last Contact</th>
            <th style="text-align:center;">Status</th>
            <th style="width:260px; text-align:center;">Action</th>
        </tr>
    </thead>

    <tbody>
    @{
        int no = 1;
    }
    @foreach (var item in Model)
    {
        var rowClass = "";
        if (item.NextFollowupDate != null)
        {
            var d = item.NextFollowupDate.Value.Date;
            if (d < DateTime.Today)
                rowClass = "table-danger";   // 🔴 Overdue
            else if (d == DateTime.Today)
                rowClass = "table-warning";  // 🟡 Today
            else
                rowClass = "table-success";  // 🟢 Upcoming
        }

        <tr class="@rowClass">
            <td>@no</td>
            <td>@item.TaskTitle</td>
            <td>@item.PartnerName</td>
            <td>@item.Owner?.EmpName</td>
            <td>@item.NextFollowupDate?.ToString("dd/MM/yyyy")</td>
            <td>
                @if(item.LastContactDate != null)
                {
                    @(item.LastContactDate?.ToString("dd/MM/yyyy")) @("(" + item.LastContactType + ")")
                }
            </td>
            <td>@item.Status</td>
            <td style="white-space:nowrap; text-align:center;">
                <a href="/Followups/Details/@item.FollowupId" class="btn btn-sm btn-info">View</a>

                @if(isAdmin)
                {
                    <a href="/Followups/Edit/@item.FollowupId" class="btn btn-sm btn-secondary">Edit</a>

                    <form method="post" action="/Followups/Delete" style="display:inline;" onsubmit="return confirm('ต้องการลบ Follow-up นี้หรือไม่?');">
                        <input type="hidden" name="followupId" value="@item.FollowupId" />
                        <input type="hidden" name="projectId" value="@Context.Request.Query["projectId"]" />
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                }

                <form method="post" action="/Followups/MarkDone" style="display:inline;">
                    <input type="hidden" name="followupId" value="@item.FollowupId" />
                    <input type="hidden" name="projectId" value="@Context.Request.Query["projectId"]" />
                    <button class="btn btn-sm btn-success">Done</button>
                </form>


                @if(item.Status == "DONE")
                {
                    <button class="btn btn-sm btn-outline-primary" disabled title="DONE แล้ว ไม่สามารถ Log ได้">
                        Log
                    </button>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-primary"
                            onclick="openQuickLog(@item.FollowupId)">
                        Log
                    </button>
                }
            </td>
        </tr>
    no++;
    }
    </tbody>
    </table>
}

<!-- Quick Log Modal -->
<div id="quickLogModal" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
     background:#fff; padding:24px; width:420px; border-radius:10px;
     border:1px solid #e0e0e0; box-shadow:0 10px 30px rgba(0,0,0,0.25); z-index:1000;">

    <h5 style="margin-bottom:18px; font-weight:600;">Quick Follow‑up Log</h5>

    <form method="post" action="/Followups/AddLog">
        <input type="hidden" name="projectId" value="@Context.Request.Query["projectId"]" />
        <input type="hidden" name="FollowupId" id="quickFollowupId" />

        <div class="mb-2">
            <label>Contact Type</label>
            <select name="ContactType" class="form-select">
                <option value="Call">Call</option>
                <option value="Email">Email</option>
                <option value="Meeting">Meeting</option>
            </select>
        </div>

        <div class="mb-2">
            <label>Note</label>
            <textarea name="Note" class="form-control" rows="3" placeholder="บันทึกการติดต่อ..."></textarea>
        </div>

        <div class="mb-2">
            <label>Next Follow-up</label>
            <input type="date" name="NextFollowupDate" class="form-control" />
        </div>

        <div style="margin-top:16px; text-align:right;">
            <button type="button" class="btn btn-secondary" onclick="closeQuickLog()">Cancel</button>
            <button class="btn btn-primary">Save</button>
        </div>
    </form>
</div>

<script>
function openQuickLog(id){
    document.getElementById("quickFollowupId").value = id;
    document.getElementById("quickLogModal").style.display = "block";
}

function closeQuickLog(){
    document.getElementById("quickLogModal").style.display = "none";
}
</script>