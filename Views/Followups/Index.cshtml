@model IEnumerable<ProjectTracking.Models.ProjectFollowup>

<h2>งานที่ต้องติดตาม</h2>
@if (TempData["FollowupMessage"] != null)
{
    <script>
        alert("@TempData["FollowupMessage"]");
    </script>
}
@using System.Linq
@{
    var menus = Context.Session.GetString("Menus") ?? "";
    var allowedMenus = menus.Split(',').Select(x => x.Trim()).ToList();

    bool HasMenu(string key)
    {
        return allowedMenus.Contains(key);
    }
}


<form method="get" action="/Followups/Index" class="mb-2">
    <select name="projectId"
            class="form-select"
            style="max-width:300px;"
            onchange="this.form.submit()"
            asp-items="@(new SelectList(ViewBag.Projects, "ProjectId", "ProjectName", Context.Request.Query["projectId"]))">
        <option value="">-- เลือก Project --</option>
    </select>
</form>

@if (string.IsNullOrEmpty(Context.Request.Query["projectId"]))
{
    <div class="alert alert-secondary mt-3 p-3">
        ⬆ กรุณาเลือก Project ก่อน
    </div>
}

<div class="mb-3">
@if (HasMenu("Followups.Create"))
{
    <a href="/Followups/Create?projectId=@Context.Request.Query["projectId"]" 
       class="btn btn-primary"
       title="สร้างงานติดตาม">
        + สร้างงานติดตาม
    </a>
}
else
{
    <button class="btn btn-primary" disabled title="ไม่มีสิทธิ์สร้างงานติดตาม">
        + สร้างงานติดตาม
    </button>
}
</div>

@if (!string.IsNullOrEmpty(Context.Request.Query["projectId"]))
{
    <div class="mb-2">
        <strong>จำนวน Follow-up:</strong> @Model.Count()
    </div>

    <table class="table table-bordered">
    <thead>
        <tr>
            <th style="width:60px; text-align:center;">No.</th>
            <th style="text-align:center;">Task</th>
            <th style="text-align:center;">Partner</th>
            <th style="text-align:center;">Owner</th>
            <th style="text-align:center;">Next Follow-up</th>
            <th style="text-align:center;">Last Contact</th>
            <th style="text-align:center;">Status</th>
            <th style="width:260px; text-align:center;">Action</th>
        </tr>
    </thead>

    <tbody>
    @{
        int no = 1;
    }
    @foreach (var item in Model)
    {
        var rowClass = "";
        if (item.NextFollowupDate != null)
        {
            var d = item.NextFollowupDate.Value.Date;
            if (d < DateTime.Today)
                rowClass = "table-danger";
            else if (d == DateTime.Today)
                rowClass = "table-warning";
            else
                rowClass = "table-success";
        }

        <tr class="@rowClass">
            <td>@no</td>
            <td>@item.TaskTitle</td>
            <td>@item.PartnerName</td>
            <td>@item.Owner?.EmpName</td>
            <td>@item.NextFollowupDate?.ToString("dd/MM/yyyy")</td>
            <td>
                @if(item.LastContactDate != null)
                {
                    @(item.LastContactDate?.ToString("dd/MM/yyyy")) @("(" + item.LastContactType + ")")
                }
            </td>
            <td>@item.Status</td>
            <td style="white-space:nowrap; text-align:center;">
                @if (HasMenu("Followups.Details"))
                {
                    <a href="/Followups/Details/@item.FollowupId" 
                       class="btn btn-sm btn-info"
                       title="ดูรายละเอียด">
                        View
                    </a>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-secondary" disabled title="ไม่มีสิทธิ์ดู">
                        View
                    </button>
                }

                @if (HasMenu("Followups.Edit"))
                {
                    <a href="/Followups/Edit/@item.FollowupId" 
                       class="btn btn-sm btn-secondary"
                       title="แก้ไข">
                        Edit
                    </a>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-secondary" disabled title="ไม่มีสิทธิ์แก้ไข">
                        Edit
                    </button>
                }

                @if (HasMenu("Followups.Delete"))
                {
                    <form method="post" action="/Followups/Delete" style="display:inline;" onsubmit="return confirm('ต้องการลบ Follow-up นี้หรือไม่?');">
                        <input type="hidden" name="followupId" value="@item.FollowupId" />
                        <input type="hidden" name="projectId" value="@Context.Request.Query["projectId"]" />
                        <button class="btn btn-sm btn-danger" title="ลบ">Delete</button>
                    </form>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-secondary" disabled title="ไม่มีสิทธิ์ลบ">
                        Delete
                    </button>
                }

                @if (HasMenu("Followups.Done"))
                {
                    if(item.Status == "DONE" || item.Status == "ACK")
                    {
                        <button class="btn btn-sm btn-success"
                                title="รายการนี้ถูก DONE หรือ ACK แล้ว"
                                onclick="alert('ไม่สามารถกด DONE ได้ เนื่องจากรายการนี้ถูก DONE หรือ ACK แล้ว'); return false;">
                            Done
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-success"
                                title="ปิดงาน"
                                onclick="openDonePopup(@item.FollowupId)">
                            Done
                        </button>
                    }
                }
                else
                {
                    <button class="btn btn-sm btn-outline-secondary" disabled title="ไม่มีสิทธิ์ปิดงาน">
                        Done
                    </button>
                }

                @if (HasMenu("Followups.Log"))
                {
                    if(item.Status == "DONE" || item.Status == "ACK")
                    {
                        <button class="btn btn-sm btn-outline-primary"
                                title="รายการนี้ถูก DONE หรือ ACK แล้ว"
                                onclick="alert('ไม่สามารถ Log ได้ เนื่องจากรายการนี้ถูก DONE หรือ ACK แล้ว'); return false;">
                            Log
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-primary"
                                title="บันทึกการติดตาม"
                                onclick="openQuickLog(@item.FollowupId)">
                            Log
                        </button>
                    }
                }
                else
                {
                    <button class="btn btn-sm btn-outline-secondary" disabled title="ไม่มีสิทธิ์บันทึก">
                        Log
                    </button>
                }
            </td>
        </tr>
    no++;
    }
    </tbody>
    </table>
}

<!-- Quick Log Modal -->
<div id="quickLogModal" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
     background:#fff; padding:24px; width:420px; border-radius:10px;
     border:1px solid #e0e0e0; box-shadow:0 10px 30px rgba(0,0,0,0.25); z-index:1000;">

    <h5 style="margin-bottom:18px; font-weight:600;">Quick Follow‑up Log</h5>

    <form method="post" action="/Followups/AddLog">
        <input type="hidden" name="projectId" value="@Context.Request.Query["projectId"]" />
        <input type="hidden" name="FollowupId" id="quickFollowupId" />

        <div class="mb-2">
            <label>Contact Type</label>
            <select name="ContactType" class="form-select">
                <option value="Call">Call</option>
                <option value="Email">Email</option>
                <option value="Meeting">Meeting</option>
            </select>
        </div>

        <div class="mb-2">
            <label>Note</label>
            <textarea name="Note" class="form-control" rows="3" placeholder="บันทึกการติดต่อ..."></textarea>
        </div>

        <div class="mb-2">
            <label>Next Follow-up</label>
            <input type="date" name="NextFollowupDate" class="form-control" />
        </div>

        <div style="margin-top:16px; text-align:right;">
            <button type="button" class="btn btn-secondary" onclick="closeQuickLog()">Cancel</button>
            <button class="btn btn-primary">Save</button>
        </div>
    </form>
</div>

<!-- Done Popup -->
<div id="doneModal" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
     background:#fff; padding:24px; width:420px; border-radius:10px;
     border:1px solid #e0e0e0; box-shadow:0 10px 30px rgba(0,0,0,0.25); z-index:1000;">

    <h5 style="margin-bottom:18px; font-weight:600;">Mark Follow‑up Done</h5>

    <form method="post" action="/Followups/MarkDone">
        <input type="hidden" name="followupId" id="doneFollowupId" />
        <input type="hidden" name="projectId" value="@Context.Request.Query["projectId"]" />

        <div class="mb-2">
            <label>Note</label>
            <textarea name="Note" class="form-control" rows="3"
                      placeholder="บันทึกผลการดำเนินการ..."></textarea>
        </div>

        <div style="margin-top:16px; text-align:right;">
            <button type="button" class="btn btn-secondary" onclick="closeDonePopup()">Cancel</button>
            <button class="btn btn-success">Done</button>
        </div>
    </form>
</div>

<script>
function openQuickLog(id){
    document.getElementById("quickFollowupId").value = id;
    document.getElementById("quickLogModal").style.display = "block";
}

function closeQuickLog(){
    document.getElementById("quickLogModal").style.display = "none";
}

function openDonePopup(id){
    document.getElementById("doneFollowupId").value = id;
    document.getElementById("doneModal").style.display = "block";
}

function closeDonePopup(){
    document.getElementById("doneModal").style.display = "none";
}
</script>