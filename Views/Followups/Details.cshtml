@model ProjectTracking.Models.ProjectFollowup

<h3 class="fw-bold mb-3">📌 Follow‑up Detail</h3>

<div class="card mb-4 shadow-sm">
<div class="card-body">

<div class="row mb-2">
    <div class="col-md-3 text-muted">Project</div>
    <div class="col-md-9 fw-semibold">@Model.Project?.ProjectName</div>
</div>

<div class="row mb-2">
    <div class="col-md-3 text-muted">Owner</div>
    <div class="col-md-9 fw-semibold">@Model.Owner?.EmpName</div>
</div>

<div class="row mb-2">
    <div class="col-md-3 text-muted">Task</div>
    <div class="col-md-9 fw-semibold">@Model.TaskTitle</div>
</div>

<div class="row mb-2">
    <div class="col-md-3 text-muted">Partner</div>
    <div class="col-md-9 fw-semibold">@Model.PartnerName</div>
</div>

<hr/>

<div class="row mb-2">
    <div class="col-md-3 text-muted">Next Follow‑up</div>
    <div class="col-md-3 fw-semibold">
        @Model.NextFollowupDate?.ToString("dd/MM/yyyy")
    </div>

    <div class="col-md-3 text-muted">Last Contact</div>
    <div class="col-md-3 fw-semibold">
        @if(Model.LastContactDate != null)
        {
            @Model.LastContactDate?.ToString("dd/MM/yyyy HH:mm")
        }
    </div>
</div>

<div class="row mb-2">
    <div class="col-md-3 text-muted">Contact Type</div>
    <div class="col-md-3 fw-semibold">@Model.LastContactType</div>

    <div class="col-md-3 text-muted">Created</div>
    <div class="col-md-3 fw-semibold">
        @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
    </div>
</div>

<div class="row mb-2">
    <div class="col-md-3 text-muted">Status</div>
    <div class="col-md-3">
        <span class="badge bg-primary px-3 py-2">@Model.Status</span>
    </div>
</div>

</div>
</div>


<h5 class="fw-bold mb-3">📜 History</h5>

<div class="card shadow-sm">
<div class="card-body p-0">

<table class="table table-hover table-bordered mb-0">
<thead class="table-light">
<tr>
<th style="width:180px;">Date</th>
<th style="width:120px;">Type</th>
<th>Note</th>
</tr>
</thead>

<tbody>

@foreach(var log in (List<ProjectTracking.Models.ProjectFollowupLog>)ViewBag.Logs)
{
<tr>
<td>@log.ContactDate.ToString("dd/MM/yyyy HH:mm")</td>
<td>@log.ContactType</td>
<td>@log.Note</td>
</tr>
}

</tbody>
</table>

</div>
</div>


<div class="mt-4">
    <a asp-action="Index"
       asp-route-projectId="@Model.ProjectId"
       class="btn btn-secondary">
        ← Back
    </a>
</div>