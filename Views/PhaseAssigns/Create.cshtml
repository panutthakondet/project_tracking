@model ProjectTracking.Models.PhaseAssign

@{
    ViewData["Title"] = "Assign Employee";
}

<div class="mb-4">
    <h2 class="fw-bold">➕ Assign Employee</h2>
    <p class="text-muted mb-0">
        มอบหมายพนักงานให้กับ Phase ของโครงการ
    </p>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <form asp-action="Create"
              method="post"
              onsubmit="return confirm('Assign Employee คนนี้หรือไม่?');">

            @Html.AntiForgeryToken()

            <input type="hidden" name="projectId" value="@ViewBag.ProjectId" />

            <!-- ส่งค่า phase_order กลับ Controller: ดึงจาก 🧩 Phase ที่เลือก (มาจาก project_phase) -->
            <input asp-for="PhaseOrder" type="hidden" id="phaseOrderHidden" />

            <div class="row g-3">

                <!-- EMPLOYEE -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">👤 Employee</label>
                    <select asp-for="EmpId" asp-items="ViewBag.Employees" class="form-select" required>
                        <option value="">-- Select Employee --</option>
                    </select>
                    <span asp-validation-for="EmpId" class="text-danger"></span>
                </div>

                <!-- PHASE -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">🧩 Phase</label>
                    <select asp-for="PhaseId"
                            class="form-select"
                            required
                            id="phaseSelect">
                        <option value="" selected>-- Select Phase --</option>

                        @* ใช้ PhaseItems (ส่งมาจาก Controller) เพื่อใส่ data-* ให้ JS ดึงค่าได้ทันที *@
                        @if (ViewBag.PhaseItems != null)
                        {
                            foreach (var ph in ViewBag.PhaseItems)
                            {
                                var ps = ph.PlanStart == null ? "" : ((DateTime)ph.PlanStart).ToString("yyyy-MM-dd");
                                var pe = ph.PlanEnd == null ? "" : ((DateTime)ph.PlanEnd).ToString("yyyy-MM-dd");
                                <option value="@ph.PhaseId"
                                        data-role="@ph.PhaseName"
                                        data-plan-start="@ps"
                                        data-plan-end="@pe"
                                        data-phase-order="@(ph.PhaseOrder == null ? "" : ph.PhaseOrder.ToString())">
                                    @ph.PhaseName
                                </option>
                            }
                        }
                        else
                        {
                            @* fallback ถ้า Controller ยังไม่ได้ส่ง PhaseItems *@
                            @if (ViewBag.Phases != null)
                            {
                                foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Phases)
                                {
                                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                }
                            }
                        }
                    </select>
                </div>

                <!-- ROLE SHOW -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">🎯 Role (Auto)</label>
                    <input asp-for="Role" type="text" class="form-control" id="roleDisplay" placeholder="ระบุ Role" autocomplete="off" />
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>

                <!-- PLAN START -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">📅 Plan Start</label>
                    <input asp-for="PlanStart" type="date" class="form-control" id="planStart" />
                </div>

                <!-- PLAN END -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">📅 Plan End</label>
                    <input asp-for="PlanEnd" type="date" class="form-control" id="planEnd" />
                </div>

                <!-- REMARK -->
                <div class="col-md-12">
                    <label class="form-label fw-semibold">📝 Remark</label>
                    <textarea asp-for="Remark" class="form-control" rows="3"></textarea>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">💾 Save Assign</button>
                <a asp-action="Index" asp-route-projectId="@ViewBag.ProjectId" class="btn btn-outline-secondary">↩ Back</a>
            </div>

        </form>
    </div>
</div>

<script>
(function () {
    function onReady(fn) {
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", fn);
        } else {
            fn();
        }
    }

    function findOptionByValue(selectEl, value) {
        if (!selectEl) return null;
        if (value == null) return null;
        // ใช้ CSS.escape เผื่อ value มีอักขระพิเศษ
        const esc = (window.CSS && CSS.escape) ? CSS.escape(String(value)) : String(value).replace(/"/g, '\\"');
        return selectEl.querySelector('option[value="' + esc + '"]');
    }

    onReady(function () {
        const phaseSelect = document.getElementById("phaseSelect");
        const planStart = document.getElementById("planStart");
        const planEnd = document.getElementById("planEnd");
        let planStartTouched = false;
        let planEndTouched = false;
        const roleDisplay = document.getElementById("roleDisplay");
        const phaseOrderHidden = document.getElementById("phaseOrderHidden");

        // Track whether user manually edited Role; keep auto-follow if Role still equals last auto value
        let roleTouched = false;
        let lastAutoRole = (roleDisplay && roleDisplay.value) ? roleDisplay.value.trim() : "";

        if (roleDisplay) {
            roleDisplay.addEventListener('input', function () {
                roleTouched = true;
                // If user clears role, allow auto again
                if (!roleDisplay.value || roleDisplay.value.trim() === "") {
                    roleTouched = false;
                }
            });
        }

        if (planStart) {
            planStart.addEventListener('input', function () {
                planStartTouched = true;
            });
        }

        if (planEnd) {
            planEnd.addEventListener('input', function () {
                planEndTouched = true;
            });
        }

        if (!phaseSelect) return;

        // force default empty selection
        phaseSelect.selectedIndex = 0;
        clearTimeout(window.__phaseInit);
        window.__phaseInit = setTimeout(() => {
            phaseSelect.value = "";
        }, 0);

        function clearAll() {
            if (planStart) planStart.value = "";
            if (planEnd) planEnd.value = "";
            if (roleDisplay) roleDisplay.value = "";
            if (phaseOrderHidden) phaseOrderHidden.value = "";
        }

        function applyFromValue(value) {
            const opt = findOptionByValue(phaseSelect, value) || phaseSelect.options[phaseSelect.selectedIndex];

            if (!opt || !opt.value) {
                clearAll();
                return;
            }

            // role (default) = phase name
            const roleDefault = (opt.dataset.role || opt.text || "").toString().trim();

            // phase_order (from project_phase) stored in option data attribute
            const phaseOrder = (opt.dataset.phaseOrder || "").toString().trim();

            // ค่าที่ส่งมาควรเป็น yyyy-MM-dd เพื่อใส่ input[type=date]
            const ps = (opt.dataset.planStart || "").toString().trim();
            const pe = (opt.dataset.planEnd || "").toString().trim();

            // เติมค่าเริ่มต้นลงช่อง Role ให้ผู้ใช้แก้ได้
            // เปลี่ยน Role ตาม Phase เฉพาะเมื่อผู้ใช้ยังไม่แก้เอง หรือ Role ยังเท่ากับค่าที่ auto ครั้งก่อน
            if (roleDisplay) {
                const curRole = (roleDisplay.value || "").toString().trim();
                if (!roleTouched || curRole === "" || (lastAutoRole && curRole === lastAutoRole)) {
                    roleDisplay.value = roleDefault;
                    lastAutoRole = roleDefault;
                }
            }

            // sync phase_order ส่งกลับ
            if (phaseOrderHidden) {
                phaseOrderHidden.value = phaseOrder;
            }

            if (planStart && !planStartTouched) planStart.value = ps;
            if (planEnd && !planEndTouched) planEnd.value = pe;
        }

        function applyFromSelectedOption() {
            applyFromValue(phaseSelect.value);
        }

        // กันผูก event ซ้ำ
        if (!phaseSelect.dataset.phasePlanBound) {
            phaseSelect.dataset.phasePlanBound = "1";

            // native change
            phaseSelect.addEventListener("change", applyFromSelectedOption);

            // รองรับ Select2 (ถ้าใช้)
            if (window.jQuery && window.jQuery.fn && window.jQuery.fn.select2) {
                window.jQuery(phaseSelect)
                    .on("select2:select", function (e) {
                        const id = (e && e.params && e.params.data && e.params.data.id) ? e.params.data.id : phaseSelect.value;
                        applyFromValue(id);
                    })
                    .on("select2:clear", function () {
                        clearAll();
                    })
                    .on("change.select2", function () {
                        applyFromSelectedOption();
                    });
            }
        }

        // โหลดค่าเริ่มต้น (กรณีมี PhaseId ติดมา)
        applyFromSelectedOption();
        if (roleDisplay && roleDisplay.value) lastAutoRole = roleDisplay.value.trim();
    });
})();
</script>