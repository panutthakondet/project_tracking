@model ProjectTracking.Models.TestScenario

<h2>Edit Test Scenario (@Model.scenario_code)</h2>

<style>
    .form-control::placeholder {
        color: #6c757d;
        opacity: 1;
    }
    .image-card:hover {
        transform: scale(1.03);
        transition: 0.2s;
    }
</style>

<form asp-action="Edit" method="post" enctype="multipart/form-data" onsubmit="return confirm('ยืนยันการแก้ไข Test Scenario นี้หรือไม่?');">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="scenario_id" />
    <input type="hidden" asp-for="scenario_code" />
    <input type="hidden" asp-for="project_id" />

    <div class="form-group">
        <label>Project</label>
        <select class="form-control" disabled>
            @if (ViewBag.Projects != null)
            {
                foreach (var p in ViewBag.Projects)
                {
                    if (p.ProjectId == Model.project_id)
                    {
                        <option value="@p.ProjectId" selected>@p.ProjectName</option>
                    }
                }
            }
        </select>
    </div>

    <div class="form-group">
        <label>Scenario Group</label>

        @if (ViewBag.SelectedGroup != null)
        {
            <input type="hidden" asp-for="group_id" />

            <select class="form-control" disabled>
                @if (ViewBag.Groups != null)
                {
                    foreach (var g in ViewBag.Groups)
                    {
                        if (g.group_id == Model.group_id)
                        {
                            <option value="@g.group_id" selected>@g.group_name</option>
                        }
                    }
                }
            </select>
        }
        else
        {
            <select asp-for="group_id" class="form-control" required>
                <option value="" selected disabled>-- Select Scenario Group --</option>
                @if (ViewBag.Groups != null)
                {
                    foreach (var g in ViewBag.Groups)
                    {
                        <option value="@g.group_id" selected="@(g.group_id == Model.group_id ? "selected" : null)">@g.group_name</option>
                    }
                }
            </select>

            <span asp-validation-for="group_id" class="text-danger"></span>
        }
    </div>

    <div class="form-group">
        <label>Title</label>
        <input asp-for="title" class="form-control"
               placeholder="เช่น ทดสอบการเข้าสู่ระบบด้วยข้อมูลถูกต้อง" />
    </div>

    <div class="form-group">
        <label>Precondition</label>
        <textarea asp-for="precondition" class="form-control" rows="3"
                  placeholder="เช่น ผู้ใช้ต้อง Login เข้าระบบแล้ว"></textarea>
    </div>

    <div class="form-group">
        <label>Steps</label>
        <textarea asp-for="steps" class="form-control" rows="5"
                  placeholder="1. เปิดหน้า....&#10;2. กรอกข้อมูล....&#10;3. กดปุ่มบันทึก"></textarea>
    </div>

    <div class="form-group">
        <label>Expected Result</label>
        <textarea asp-for="expected_result" class="form-control" rows="5"
                  placeholder="เช่น&#10;1. ระบบเข้าสู่หน้า...&#10;2. แสดงข้อความบันทึกสำเร็จ&#10;3. แสดง error เมื่อข้อมูลผิด"></textarea>
    </div>

    <div class="form-group">
        <label>Priority</label>
        <select asp-for="priority" class="form-control">
            <option>LOW</option>
            <option>MEDIUM</option>
            <option>HIGH</option>
        </select>
    </div>

    <div class="form-group">
        <label>Status</label>
        <select asp-for="status" class="form-control">
            <option>DRAFT</option>
            <option>READY</option>
            <option>PASSED</option>
            <option>FAILED</option>
        </select>
    </div>

    <div class="form-group">
        <label>แนบรูปภาพ (เพิ่ม/อัปเดต Evidence)</label>
        <input type="file" name="files" multiple class="form-control" />
        <small class="text-muted">สามารถเพิ่มรูปเพิ่มเติมได้</small>
    </div>

    <hr />

    <h5>📸 รูปภาพที่แนบไว้</h5>

    @{
        var attachments = ViewBag.Attachments as IEnumerable<dynamic>;
    }

    @if (attachments != null && attachments.Any())
    {
        <div class="row">
            @foreach (var img in attachments)
            {
                <div class="col-md-3 mb-3 text-center image-card">
                    <img src="@img.FilePath" class="img-fluid border rounded mb-2"
                         style="max-height:150px; cursor:pointer;"
                         onclick="window.open('@img.FilePath','_blank')" />

                    <div class="border rounded p-2 d-flex align-items-center justify-content-between" style="background-color:#f8f9fa;">
                        <span class="text-muted small">ลบรูปนี้</span>
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input" type="checkbox" name="deleteAttachmentIds" value="@img.AttachmentId" id="del_@img.AttachmentId">
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">ยังไม่มีรูปภาพ</p>
    }

    <br />

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index"
       asp-route-projectId="@Model.project_id"
       asp-route-groupId="@ViewBag.SelectedGroup"
       class="btn btn-secondary">Back</a>
</form>