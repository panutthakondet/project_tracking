@model IEnumerable<ProjectTracking.Models.TestScenario>
@{
    var list = Model?.ToList() ?? new List<ProjectTracking.Models.TestScenario>();
    string projectName = ViewBag.ProjectName as string ?? "Project Name";
}

<style>
    body { font-family: Arial; }

    .page { page-break-after: always; }

    .cover {
        text-align: center;
        margin-top: 150px;
    }

    .section {
        margin-bottom: 40px;
    }

    .label { font-weight: bold; }

    .box {
        border: 1px solid #ccc;
        padding: 15px;
        margin-top: 10px;
    }

    img {
        max-width: 400px;
        margin-top: 10px;
        border: 1px solid #ccc;
    }

    @@media print {
        .no-print { display: none; }
        @@page { size: A4; margin: 15mm; }
    }
</style>

<!-- COVER -->
<div class="page cover">
    <h1>TEST SCENARIO REPORT</h1>
    <h3>@projectName</h3>
    <p>Date: @DateTime.Now.ToString("dd/MM/yyyy")</p>
</div>

<!-- DETAIL -->
@foreach (var item in list)
{
    <div class="page section">
        <h3>@item.scenario_code : @item.title</h3>

        <div class="box">
            <p><span class="label">Status:</span> @item.status</p>
            <p><span class="label">Priority:</span> @item.priority</p>
            <p><span class="label">Precondition:</span> @item.precondition</p>
            <p><span class="label">Steps:</span><br />@item.steps</p>
            <p><span class="label">Expected Result:</span> @item.expected_result</p>
        </div>

        <div>
            <p class="label">รูปภาพ</p>
            <!-- future: show attachments -->
            <p>(แนบรูปภาพจากระบบ)</p>
        </div>
    </div>
}