@model IEnumerable<ProjectTracking.Models.TestScenario>

@{
    string StatusBadge(string status)
    {
        return status switch
        {
            "PASSED" => "bg-success",
            "FAILED" => "bg-danger",
            "READY"  => "bg-primary",
            "DRAFT"  => "bg-secondary",
            _        => "bg-dark"
        };
    }

    var list = Model?.ToList() ?? new List<ProjectTracking.Models.TestScenario>();
}

<style>
    /* Make table wide enough to scroll when needed */
    .scenario-table {
        min-width: 1600px;
        table-layout: fixed;
        border-collapse: separate;
        border-spacing: 0;
        --row-col: 60px;
        --code-col: 110px;
        --title-col: 260px;
    }

    /* Sticky first columns */
    .sticky-col-0 {
        position: sticky;
        left: 0;
        z-index: 5;
        background: #fff;
        border-right: 1px solid #dee2e6;
    }
    .sticky-col {
        position: sticky;
        left: calc(var(--row-col) + 1px);
        z-index: 5;
        background: #fff;
        border-right: 1px solid #dee2e6;
    }
    .sticky-col-2 {
        position: sticky;
        left: calc(var(--row-col) + var(--code-col) + 2px);
        z-index: 5;
        background: #fff;
        border-right: 1px solid #dee2e6;
        box-shadow: 2px 0 5px -2px rgba(0,0,0,0.12);
    }

    th.sticky-col-0, td.sticky-col-0 {
        width: var(--row-col);
        min-width: var(--row-col);
        max-width: var(--row-col);
    }
    th.sticky-col, td.sticky-col {
        width: var(--code-col);
        min-width: var(--code-col);
        max-width: var(--code-col);
    }
    th.sticky-col-2, td.sticky-col-2 {
        width: var(--title-col);
        min-width: var(--title-col);
        max-width: var(--title-col);
    }

    /* Keep header above body */
    thead th { position: sticky; top: 0; z-index: 7; background: #f8f9fa; }

    /* Group header row (normal, not sticky) */
    .group-header-row td {
        background: #eef3ff;
        font-weight: 600;
        border-bottom: 2px solid #cfe0ff;
    }

    /* Ensure sticky body cells stay above striped rows */
    tbody td.sticky-col-0, tbody td.sticky-col, tbody td.sticky-col-2 { z-index: 3; }

    /* Improve readability for long text */
    .multiline-cell { white-space: pre-line; vertical-align: top; }

    .nowrap-cell { white-space: nowrap; }

    /* Header area */
    .page-header-card { border: 1px solid #e9ecef; border-radius: 10px; background: #fff; }
    .page-header-card .card-body { padding: 16px; }
    .toolbar { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }

    /* Colored table header */
    .scenario-table thead th {
        background-color: #0d6efd !important;
        color: #ffffff;
        text-align: center;
        vertical-align: middle;
    }

    /* Center specific columns */
    .text-center-col {
        text-align: center;
        vertical-align: middle;
    }

    .drag-handle {
        font-size: 16px;
    }
</style>

<h2 class="mb-3">Test Scenarios</h2>

<div class="page-header-card mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-7">
                    <label class="form-label">Select Project</label>
                    @{
                        int? selProject = null;
                        if (ViewBag.SelectedProject != null)
                        {
                            selProject = Convert.ToInt32(ViewBag.SelectedProject);
                        }
                    }
                    <select name="projectId"
                            class="form-select"
                            onchange="this.form.submit()">
                        <option value="">-- Select Project --</option>
                        @if (ViewBag.Projects != null)
                        {
                            foreach (var p in ViewBag.Projects)
                            {
                                <option value="@p.ProjectId"
                                        selected="@(selProject == p.ProjectId ? "selected" : null)">
                                    @p.ProjectName
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12 col-lg-5">
                    <label class="form-label">Select Group</label>
                    @{
                        int? selGroup = null;
                        if (ViewBag.SelectedGroup != null)
                        {
                            selGroup = Convert.ToInt32(ViewBag.SelectedGroup);
                        }
                    }
                    <select name="groupId"
                            class="form-select"
                            onchange="this.form.submit()">
                        <option value="">-- Select Group --</option>
                        @if (ViewBag.Groups != null)
                        {
                            foreach (var g in ViewBag.Groups)
                            {
                                <option value="@g.group_id"
                                        selected="@(selGroup == g.group_id ? "selected" : null)">
                                    @g.group_name
                                </option>
                            }
                        }
                    </select>
                </div>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.SelectedProject != null)
{
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div class="toolbar">
            <a asp-action="Create"
               asp-route-projectId="@ViewBag.SelectedProject"
               asp-route-groupId="@ViewBag.SelectedGroup"
               class="btn btn-success">
                + Add Scenario
            </a>

            <a asp-action="ImportTemplates"
               asp-route-projectId="@ViewBag.SelectedProject"
               asp-route-groupId="@ViewBag.SelectedGroup"
               class="btn btn-primary"
               onclick="return confirm('Import template ตาม Group ที่เลือกเข้าโครงการนี้?');">
                Import Templates
            </a>

            <form asp-action="DeleteAll"
                  asp-route-projectId="@ViewBag.SelectedProject"
                  method="post"
                  style="display:inline;"
                  onsubmit="return confirm('ลบ Test Scenario ทั้งหมดของโครงการนี้? การกระทำนี้ไม่สามารถย้อนกลับได้');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Delete All</button>
            </form>
            <a asp-action="ExportPdf"
               asp-route-projectId="@ViewBag.SelectedProject"
               class="btn btn-warning">
                📄 Export PDF
            </a>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <span class="badge bg-dark">Total: @list.Count</span>
            <span class="badge bg-success">Passed: @list.Count(x => x.status == "PASSED")</span>
            <span class="badge bg-danger">Failed: @list.Count(x => x.status == "FAILED")</span>
            <span class="badge bg-primary">Ready: @list.Count(x => x.status == "READY")</span>
            <span class="badge bg-secondary">Draft: @list.Count(x => x.status == "DRAFT")</span>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-striped table-sm align-middle scenario-table">
        <thead>
            <tr>
                <th class="sticky-col-0" style="width:60px;">#</th>
                <th class="sticky-col" style="width:110px;">Code</th>
                <th class="sticky-col-2" style="width:260px;">Title</th>
                <th style="width:110px;" class="text-center-col">Status</th>
                <th style="width:110px;" class="text-center-col">Priority</th>
                <th style="width:220px;">Precondition</th>
                <th style="width:320px;">Steps</th>
                <th style="width:320px;">Expected Result</th>
                <th style="width:150px;">Created</th>
                <th style="width:150px;">Updated</th>
                <th style="width:160px;" class="text-center-col">Edit / Delete</th>
            </tr>
        </thead>
        <tbody id="scenarioTableBody">
        @{ var rowNo = 1; }
        @foreach (var grp in list.GroupBy(x => x.Group?.group_name ?? "No Group"))
        {
            <tr class="group-header-row" data-group="@grp.Key">
                <td colspan="11">
                    Group : @grp.Key (Total: @grp.Count())
                </td>
            </tr>

            foreach (var item in grp)
            {
                <tr data-id="@item.scenario_id" data-group="@grp.Key">
                    <td class="sticky-col-0">
                        <span class="drag-handle" style="cursor:grab;margin-right:6px;color:#6c757d;">☰</span>
                        @rowNo
                    </td>
                    <td class="sticky-col">@item.scenario_code</td>
                    <td class="sticky-col-2">@item.title</td>
                    <td class="text-center-col"><span class="badge @StatusBadge(item.status)">@item.status</span></td>
                    <td class="text-center-col">@item.priority</td>
                    <td class="multiline-cell">@item.precondition</td>
                    <td class="multiline-cell">@item.steps</td>
                    <td class="multiline-cell">@item.expected_result</td>
                    <td class="nowrap-cell">@item.created_at.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="nowrap-cell">@item.updated_at?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-center-col">
                        <a asp-action="Edit" asp-route-id="@item.scenario_id"
                           class="btn btn-sm btn-warning">Edit</a>

                        <form asp-action="Delete"
                              asp-route-id="@item.scenario_id"
                              method="post"
                              style="display:inline;"
                              onsubmit="return confirm('Delete this scenario?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                    @{ rowNo++; }
                </tr>
            }
        }
        </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">
        กรุณาเลือก Group และโครงการก่อน เพื่อดู/เพิ่ม Test Scenario
    </div>
}
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tbody = document.getElementById("scenarioTableBody");

        if (!tbody) return;

        new Sortable(tbody, {
            animation: 150,
            handle: ".drag-handle",
            ghostClass: "table-warning",

            onStart: function (evt) {
                evt.item.dataset.startGroup = evt.item.dataset.group;
            },

            onEnd: function (evt) {
                const movedRow = evt.item;
                const startGroup = movedRow.dataset.startGroup;

                // Find nearest GROUP HEADER row above the dropped row
                let prev = movedRow.previousElementSibling;
                while (prev && !(prev.classList && prev.classList.contains('group-header-row'))) {
                    prev = prev.previousElementSibling;
                }

                const targetGroup = prev && prev.dataset ? prev.dataset.group : startGroup;

                // If the row was dropped above its own group header, treat it as same group
                if (!prev && startGroup) {
                    // no header found above; keep original group
                }

                if (targetGroup !== startGroup) {
                    alert("ไม่สามารถลาก Scenario ข้าม Group ได้");
                    location.reload();
                    return;
                }

                const rows = tbody.querySelectorAll("tr[data-id]");
                const ids = [];

                rows.forEach(r => ids.push(r.dataset.id));

                fetch("/TestScenarios/Reorder", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(ids)
                });
            }
        });
    });
</script>