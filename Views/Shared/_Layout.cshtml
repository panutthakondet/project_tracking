        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                ProjectTracking
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                @if (userId != null)
                {
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <!-- Home (always) -->
                        <li class="nav-item">
                            <a class="nav-link @(controller=="Home"?"active-menu":"")" asp-controller="Home" asp-action="Index">🏠 หน้าแรก</a>
                        </li>


                        <!-- Dashboards -->
                        @if (canDashboards)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(controller=="IssueDashboard" || controller=="Dashboard" ? "active-menu" : "")"
                                   href="#" role="button" data-bs-toggle="dropdown">📊 แดชบอร์ด</a>
                                <ul class="dropdown-menu">
                                    @if (HasMenu("IssueDashboard.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="IssueDashboard" asp-action="Index">📊 ภาพรวมทั้งโครงการ</a></li>
                                    }
                                    @if (CanMenu("Dashboard.Index"))
                                    {
                                        <li><a class="dropdown-item" href="/Followups/Dashboard">📌 Dashboard งานติดตาม</a></li>
                                    }
                                    @if (CanMenu("Dashboard.Workload"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="Workload">🔥 สถานะภาระงานพนักงาน</a></li>
                                    }
                                </ul>
                            </li>
                        }

                        <!-- Management -->
                        @if (canManagement)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(
                                    controller=="Employees" 
                                    || controller=="Projects" 
                                    || controller=="ProjectPhases" 
                                    || controller=="PhaseAssigns" 
                                    || controller=="Meetings" 
                                    || controller=="TestScenarios"
                                    || controller=="TestScenarioTemplates"
                                    || controller=="TestTemplateGroups"
                                    || controller=="ProjectDocuments"
                                    ? "active-menu" : "")"
                                   href="#" role="button" data-bs-toggle="dropdown">📁 จัดการโครงการ</a>
                                <ul class="dropdown-menu">
                                    @if (CanMenu("Employees.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Employees" asp-action="Index">👤 บันทึกข้อมูลพนักงาน</a></li>
                                    }
                                    @if (HasMenu("Projects.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Projects" asp-action="Index">📁 บันทึกข้อมูลโครงการ</a></li>
                                    }
                                    @if (CanMenu("ProjectPhases.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="ProjectPhases" asp-action="Index">🧩 บันทึกข้อมูลแผนงานและงวดงาน</a></li>
                                    }
                                    @if (CanMenu("PhaseAssigns.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="PhaseAssigns" asp-action="Index">👥 บันทึกข้อมูลการมอบหมายงาน</a></li>
                                    }
                                    @if (CanMenu("TestScenarios.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="TestScenarios" asp-action="Index">🧪 บันทึก Test Scenario</a></li>
                                    }
                                    @if (CanMenu("TestScenarioTemplates.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="TestScenarioTemplates" asp-action="Index">📋 จัดการ Test Scenario Template</a></li>
                                    }
                                    @if (CanMenu("TestTemplateGroups.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="TestTemplateGroups" asp-action="Index">🗂 จัดการ Template Group</a></li>
                                    }
                                    @if (CanMenu("ProjectDocuments.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="ProjectDocuments" asp-action="Index">📄 เอกสารโครงการ (BRD / TOR)</a></li>
                                    }
                                </ul>
                            </li>
                        }

                        <!-- Issues -->
                        @if (canIssues)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(controller=="ProjectIssues" ? "active-menu" : "")"
                                   href="#" role="button" data-bs-toggle="dropdown">🐞 ปัญหาโครงการ</a>
                                <ul class="dropdown-menu">
                                    @if (CanMenu("ProjectIssues.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="ProjectIssues" asp-action="Index">🐞 บันทึกข้อมูลปัญหาโครงการ</a></li>
                                    }
                                    @if (CanMenu("ProjectIssues.ViewOnly"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="ProjectIssues" asp-action="ViewOnly">📝 รายงานปัญหาและสถานะโครงการ</a></li>
                                    }
                                    @if (CanMenu("ProjectIssues.DevIndex"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="ProjectIssues" asp-action="DevIndex">👨‍💻 แก้ไขสถานะปัญหาโครงการ</a></li>
                                    }
                                    @if (CanMenu("SupportOrders.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="SupportOrders" asp-action="Index">🛠️ งานแก้ไขช่วงรับประกัน</a></li>
                                    }
                                    @if (CanMenu("SupportOrdersDev.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="SupportOrdersDev" asp-action="Index">👨‍💻 งานแก้ไขช่วงรับประกัน (Dev)</a></li>
                                    }
                                </ul>
                            </li>
                        }

                        <!-- Reports -->
                        @if (canReports)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(
                                    ((controller=="PhaseAssigns" && action=="Print") || controller=="PhaseStatusReport")
                                        ? "active-menu" : "")"
                                   href="#" role="button" data-bs-toggle="dropdown">📄 รายงาน</a>
                                <ul class="dropdown-menu">
                                    @if (CanMenu("PhaseAssigns.Print"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="PhaseAssigns" asp-action="Print">📄 รายงานการมอบหมายงาน</a></li>
                                    }
                                    @if (CanMenu("PhaseStatusReport.Index"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="PhaseStatusReport" asp-action="Index">📊 รายงานสถานะงานค้าง</a></li>
                                    }
                                    @if (CanMenu("PhaseStatusReport.Timeline"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="PhaseStatusReport" asp-action="Timeline">📅 Timeline / Gantt</a></li>
                                    }
                                    @if (CanMenu("Projects.ViewOnly"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Projects" asp-action="ViewOnly">📁 รายงานข้อมูลโครงการ</a></li>
                                    }
                                </ul>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav align-items-center">

                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle navbar-text text-white"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown">
                                👤 @username
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                @if (CanMenu("UserManagement.Index"))
                                {
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="UserManagement"
                                           asp-action="Index">
                                           ⚙️ จัดการผู้ใช้งาน
                                        </a>
                                    </li>
                                }

                                <li>
                                    <hr class="dropdown-divider">
                                </li>

                                <li>
                                    <a class="dropdown-item text-danger"
                                       asp-controller="Auth"
                                       asp-action="Logout">
                                       🚪 Logout
                                    </a>
                                </li>

                            </ul>
                        </li>

                    </ul>
                }
                else
                {
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(controller=="Home"?"active-menu":"")" asp-controller="Home" asp-action="Index">🏠 หน้าแรก</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a class="btn btn-logout btn-sm" asp-controller="Auth" asp-action="Login">Login</a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>
</header>

