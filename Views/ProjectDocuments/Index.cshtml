@model IEnumerable<ProjectTracking.Models.ProjectDocument>

@{
    ViewData["Title"] = "Project Documents";
    var projectId = ViewBag.ProjectId;
}

@using Microsoft.AspNetCore.Http
@{
    bool CanMenu(string key)
    {
        var menus = Context.Session.GetString("Menus") ?? "";
        return menus.Contains(key);
    }
}

<div class="container mt-4">

    <h3 class="mb-3">📂 Project Documents</h3>

    <!-- Upload Section -->
    <div class="card mb-4">
        <div class="card-header fw-bold">
            Upload Document
        </div>
        <div class="card-body">
            @if (CanMenu("ProjectDocuments.Upload"))
            {
                <form asp-action="Upload" method="post" enctype="multipart/form-data" onsubmit="return confirm('อัปโหลดไฟล์นี้หรือไม่?');">
                    <input type="hidden" name="projectId" value="@projectId" />

                    <div class="row g-3">

                        <div class="col-md-3">
                            <label class="form-label">Document Type</label>
                            <select name="documentType" class="form-select" required>
                                <option value="BRD">BRD</option>
                                <option value="TOR">TOR</option>
                                <option value="DESIGN">Design</option>
                                <option value="OTHER">Other</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">File</label>
                            <input type="file" name="file" class="form-control" required />
                        </div>

                        <div class="col-md-3 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100" title="อัปโหลดเอกสาร">
                                ⬆ Upload
                            </button>
                        </div>

                    </div>
                </form>
            }
            else
            {
                <button class="btn btn-primary w-100" disabled title="ไม่มีสิทธิ์อัปโหลดเอกสาร">
                    ⬆ Upload
                </button>
            }
        </div>
    </div>


    <!-- Documents Table -->
    <div class="card">

        <div class="card-header fw-bold">
            Document List
        </div>

        <div class="card-body p-0">

            <table class="table table-striped table-hover mb-0">

                <thead class="table-dark">
                    <tr>
                        <th style="width:80px">ID</th>
                        <th style="width:120px">Type</th>
                        <th>File Name</th>
                        <th style="width:160px">Uploaded</th>
                        <th style="width:300px" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                No documents uploaded
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var doc in Model)
                        {
                            <tr>
                                <td>@doc.DocumentId</td>

                                <td>
                                    <span class="badge bg-secondary">
                                        @doc.DocumentType
                                    </span>
                                </td>

                                <td>
                                    @doc.FileName
                                </td>

                                <td>
                                    @doc.UploadedAt.ToString("yyyy-MM-dd HH:mm")
                                </td>

                                <td>
                                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                                        @if (CanMenu("ProjectDocuments.Preview"))
                                        {
                                            <a asp-action="Preview"
                                               asp-route-id="@doc.DocumentId"
                                               target="_blank"
                                               class="btn btn-sm btn-info"
                                               title="ดูไฟล์"
                                               onclick="return confirm('ต้องการเปิดดูไฟล์นี้หรือไม่?');">
                                                👁 Preview
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" disabled title="ไม่มีสิทธิ์ดูไฟล์">
                                                👁 Preview
                                            </button>
                                        }

                                        @if (CanMenu("ProjectDocuments.Download"))
                                        {
                                            <a asp-action="Download"
                                               asp-route-id="@doc.DocumentId"
                                               class="btn btn-sm btn-success"
                                               title="ดาวน์โหลดไฟล์">
                                                ⬇ Download
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" disabled title="ไม่มีสิทธิ์ดาวน์โหลด">
                                                ⬇ Download
                                            </button>
                                        }

                                        @if (CanMenu("ProjectDocuments.Delete"))
                                        {
                                            <a asp-action="Delete"
                                               asp-route-id="@doc.DocumentId"
                                               class="btn btn-sm btn-danger"
                                               title="ลบเอกสาร"
                                               onclick="return confirm('Delete this document?');">
                                                🗑 Delete
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" disabled title="ไม่มีสิทธิ์ลบ">
                                                🗑 Delete
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>