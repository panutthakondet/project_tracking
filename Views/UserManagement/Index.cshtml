@using System
@using System.Linq
@model IEnumerable<ProjectTracking.Models.LoginUser>

@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="fw-bold mb-0">👤 จัดการผู้ใช้งาน</h2>
        <div class="text-muted">จัดการผู้ใช้งาน (เพิ่ม / แก้ไข / กำหนดสิทธิ์)</div>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="border-radius:12px; font-weight:800;">➕ Create User</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-warning">@TempData["Error"]</div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Email Verified</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-4">ยังไม่มีผู้ใช้งาน</td>
            </tr>
        }
        else
        {
            foreach (var u in Model)
            {
                <tr>
                    <td class="fw-semibold">@u.Username</td>
                    <td>@u.Email</td>
                    <td><span class="badge bg-secondary">@u.Role</span></td>
                    <td>
                        @if ((u.Status ?? "").Equals("ACTIVE", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge bg-success">ACTIVE</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">INACTIVE</span>
                        }
                    </td>
                    <td>
                        @if (u.EmailVerified)
                        {
                            <span class="badge bg-success">YES</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">NO</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-username="@u.Username" class="btn btn-sm btn-outline-secondary" style="border-radius:12px; font-weight:800; margin-right:6px;">✏️ Edit</a>
                        <a asp-action="Permissions" asp-route-username="@u.Username" class="btn btn-sm btn-outline-primary" style="border-radius:12px; font-weight:800; margin-right:6px;">🔐 Menus</a>

                        <form asp-action="Delete"
                              asp-route-username="@u.Username"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="btn btn-sm btn-outline-danger"
                                    style="border-radius:12px; font-weight:800;"
                                    onclick="return confirm('ยืนยันการลบผู้ใช้งาน @u.Username ?');">
                                🗑 Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
<style>
    table td {
        word-break: break-word;
    }
</style>