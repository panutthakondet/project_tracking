@model ProjectTracking.Models.LoginUser

@{
    ViewData["Title"] = "Edit User";

    // Prefer ViewBag.Error, otherwise show TempData["Error"] if present
    string? error = (ViewBag.Error as string) ?? (TempData["Error"] as string);
    string? success = TempData["Success"] as string;

    // Repopulate inputs safely from ModelState (works for POST-back without using Request.Form)
    string Ms(string key) => ViewData.ModelState.TryGetValue(key, out var e) ? e.AttemptedValue ?? "" : "";

    var vEmail = Ms("email");
    var vRole = Ms("role");
    var vStatus = Ms("status");

    var vEmpId = Ms("emp_id");

    // Fallback to model values on first load (support different property names)
    if (string.IsNullOrWhiteSpace(vEmpId) && Model != null)
    {
        var t = Model.GetType();
        var p = t.GetProperty("EmpId") ?? t.GetProperty("Emp_id") ?? t.GetProperty("EmpID") ?? t.GetProperty("emp_id");
        var val = p?.GetValue(Model);
        if (val != null) vEmpId = val.ToString() ?? "";
    }

    // Fallback: Controller may resolve employee via employee.login_user_id mapping
    if (string.IsNullOrWhiteSpace(vEmpId) && ViewBag.CurrentEmpId != null)
    {
        vEmpId = ViewBag.CurrentEmpId.ToString();
    }

    // Fallback to model values on first load
    if (string.IsNullOrWhiteSpace(vEmail)) vEmail = Model?.Email ?? "";
    if (string.IsNullOrWhiteSpace(vRole)) vRole = Model?.Role ?? "USER";
    if (string.IsNullOrWhiteSpace(vStatus)) vStatus = Model?.Status ?? "ACTIVE";

    var vUsername = Model?.Username ?? "";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="fw-bold mb-0">✏️ Edit User</h2>
        <div class="text-muted">แก้ไขผู้ใช้งาน (บันทึกแล้วระบบจะให้ยืนยันอีเมลใหม่)</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:12px; font-weight:800;">↩ Back</a>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
@if (!string.IsNullOrWhiteSpace(success))
{
    <div class="alert alert-success">@success</div>
}

<form asp-action="Edit" method="post" class="card p-4" style="border-radius:16px;">
    @Html.AntiForgeryToken()

    <input type="hidden" name="originalUsername" value="@vUsername" />

    <div class="mb-3">
        <label class="form-label fw-bold">Username</label>
        <input class="form-control" value="@vUsername" readonly />
        <div class="form-text">ไม่สามารถแก้ไข Username ได้</div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Email</label>
        <input name="email" type="email" class="form-control" value="@vEmail" required />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Employee</label>
        <select name="emp_id" class="form-select" required>
            <option value="">-- Select Employee --</option>
            @if (ViewBag.Employees != null)
            {
                var vEmpIdTrim = (vEmpId ?? "").Trim();

                foreach (var emp in ViewBag.Employees)
                {
                    var empIdStr = (emp.emp_id?.ToString() ?? "").Trim();
                    var isSelected = !string.IsNullOrWhiteSpace(vEmpIdTrim) && vEmpIdTrim == empIdStr;

                    if (isSelected)
                    {
                        <option value="@emp.emp_id" selected="selected">@emp.emp_name</option>
                    }
                    else
                    {
                        <option value="@emp.emp_id">@emp.emp_name</option>
                    }
                }
            }
        </select>
        <div class="form-text text-muted">
            ต้องผูก User กับ Employee เพื่อให้ระบบแจ้งเตือนทำงานถูกต้อง
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Password</label>
        <input name="password" type="password" class="form-control" />
        <div class="form-text text-muted">ถ้าไม่ต้องการเปลี่ยนรหัสผ่าน ให้เว้นว่างไว้</div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Confirm Password</label>
        <input name="confirmPassword" type="password" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Role</label>
        <select name="role" class="form-select">
            @{
                var isUser = string.IsNullOrWhiteSpace(vRole) || vRole.Equals("USER", StringComparison.OrdinalIgnoreCase);
                var isAdmin = !string.IsNullOrWhiteSpace(vRole) && vRole.Equals("ADMIN", StringComparison.OrdinalIgnoreCase);
            }
            <option value="USER" selected="@(isUser ? "selected" : null)">USER</option>
            <option value="ADMIN" selected="@(isAdmin ? "selected" : null)">ADMIN</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Status</label>
        <select name="status" class="form-select">
            @{
                var isActive = string.IsNullOrWhiteSpace(vStatus) || vStatus.Equals("ACTIVE", StringComparison.OrdinalIgnoreCase);
                var isInactive = !string.IsNullOrWhiteSpace(vStatus) && vStatus.Equals("INACTIVE", StringComparison.OrdinalIgnoreCase);
            }
            <option value="ACTIVE" selected="@(isActive ? "selected" : null)">ACTIVE</option>
            <option value="INACTIVE" selected="@(isInactive ? "selected" : null)">INACTIVE</option>
        </select>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <button type="submit" class="btn btn-primary fw-bold">💾 Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

<div class="card p-4 mt-3" style="border-radius:16px;">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="fw-bold mb-1">🔐 กำหนดสิทธิ์เมนู</h5>
            <div class="text-muted">ตั้งค่าสิทธิ์การเข้าถึงเมนู เช่น ปฏิทินนัดประชุม</div>
        </div>
        <a asp-action="Permissions" asp-route-username="@vUsername" class="btn btn-outline-primary fw-bold" style="border-radius:12px;">
            ไปหน้ากำหนดสิทธิ์
        </a>
    </div>

    @{
        // Optional: show current permissions if controller passes them
        var userMenus = ViewBag.UserMenus as IEnumerable<string>;
    }

    @if (userMenus != null && userMenus.Any())
    {
        <hr />
        <div class="fw-bold mb-2">สิทธิ์ปัจจุบัน</div>
        <div class="d-flex gap-2 flex-wrap">
            @foreach (var k in userMenus)
            {
                <span class="badge bg-secondary" style="border-radius:999px; padding:8px 10px;">@k</span>
            }
        </div>
        <div class="form-text mt-2">* รายการนี้จะแสดงเมื่อ Controller ส่ง ViewBag.UserMenus มาให้</div>
    }
</div>