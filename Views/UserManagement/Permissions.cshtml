@{
    ViewData["Title"] = "Permissions";

    var username = ViewBag.Username as string ?? "";
    var groupedMenus = (ViewBag.GroupedMenus as IEnumerable<dynamic>)?.ToList() ?? new List<dynamic>();
    var selected = ViewBag.SelectedMenus as HashSet<string> ?? new HashSet<string>();
}

<h3>🔐 กำหนดสิทธิ์ผู้ใช้ (@username)</h3>

<form method="post" id="permissionForm">
    <input type="hidden" name="username" value="@username" />

    @if (groupedMenus != null && groupedMenus.Count > 0)
    {
        foreach (var group in groupedMenus)
        {
        <div style="margin-bottom:20px; border:1px solid #ddd; border-radius:10px; padding:10px;">
            
            <!-- 🔥 Controller -->
            <div style="font-weight:bold; background:#f1f5f9; padding:8px; border-radius:8px;">
                <label style="display:flex; align-items:center; gap:6px;">
                    <input type="checkbox"
                           class="chk-parent"
                           data-group="@group.ControllerLabel"
                           style="transform:scale(1.2);" />
                    📁 @group.ControllerLabel
                </label>
            </div>

            <!-- 🔥 Actions -->
            @foreach (var item in group.Items)
            {
                var isChecked = selected.Contains(item.Key?.Trim());

                <div style="padding-left:25px; margin-top:6px;">
                    <label>
                        <input type="checkbox"
                               class="chk-child"
                               data-group="@group.ControllerLabel"
                               style="transform:scale(1.2); margin-right:6px;"
                               name="menus"
                               value="@item.Key"
                               @(isChecked ? "checked" : "") />
                        └─ @item.Label
                    </label>
                    <div style="font-size:11px; color:#888;">@item.Key</div>
                </div>
            }
        </div>
        }
    }
    else
    {
        <div style="color:red; font-weight:bold;">
            ❌ ไม่พบเมนู (GroupedMenus ว่าง)
        </div>
    }

    <div style="margin-top:20px; display:flex; gap:10px;">
        <button type="submit"
                style="background:#2563eb; color:white; border:none; padding:8px 16px; border-radius:8px; font-weight:bold;">
            💾 บันทึก
        </button>

        <a href="/UserManagement"
           style="background:#e5e7eb; color:#111; padding:8px 16px; border-radius:8px; text-decoration:none; font-weight:bold;">
            🔙 ย้อนกลับ
        </a>
    </div>
</form>

<script>
document.addEventListener("DOMContentLoaded", function () {

    document.querySelectorAll(".chk-parent").forEach(parent => {

        const group = parent.getAttribute("data-group");
        const children = document.querySelectorAll(`.chk-child[data-group="${group}"]`);

        // set initial state
        const allChecked = Array.from(children).every(x => x.checked);
        const anyChecked = Array.from(children).some(x => x.checked);
        parent.checked = allChecked;
        parent.indeterminate = !allChecked && anyChecked;

        // parent click
        parent.addEventListener("change", function () {
            children.forEach(c => c.checked = parent.checked);
        });

        // child change
        children.forEach(c => {
            c.addEventListener("change", function () {
                const all = Array.from(children).every(x => x.checked);
                const any = Array.from(children).some(x => x.checked);

                parent.checked = all;
                parent.indeterminate = !all && any;
            });
        });

    });

    // 🔥 confirm before submit
    const form = document.getElementById("permissionForm");
    if (form) {
        form.addEventListener("submit", function (e) {
            const ok = confirm("💾 ยืนยันบันทึกสิทธิ์นี้หรือไม่?");
            if (!ok) {
                e.preventDefault();
            }
        });
    }

});
</script>