@model ProjectTracking.Models.ProjectSupportOrder

<h3 class="mb-3">@Model.OrderTitle</h3>

<div class="mb-3">
    <label class="fw-bold">Project</label>
    <div>@(Model.Project != null ? Model.Project.ProjectName : "-")</div>
</div>

<div class="mb-3">
    <label class="fw-bold">Detail</label>
    <div>@Model.OrderDetail</div>
</div>

<div class="row mb-3">
    <div class="col-md-3">
        <label class="fw-bold">Priority</label>
        <div>@Model.Priority</div>
    </div>

    <div class="col-md-3">
        <label class="fw-bold">Status</label>
        <div>@Model.Status</div>
    </div>

    <div class="col-md-3">
        <label class="fw-bold">Dev Status</label>
        <div>@(string.IsNullOrEmpty(Model.DevStatus) ? "-" : Model.DevStatus)</div>
    </div>

    <div class="col-md-3">
        <label class="fw-bold">Due Date</label>
        <div>@(Model.DueDate.HasValue ? Model.DueDate.Value.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("th-TH")) : "-")</div>
    </div>
</div>

<div class="mb-3">
    <label class="fw-bold">Assign To :</label>
    @(Model.Employee != null ? $"{Model.Employee.EmpName} ({Model.Employee.Position})" : "-")
</div>

<h5>BA Images</h5>

@if (Model.Images != null && Model.Images.Any())
{
    foreach (var img in Model.Images)
    {
        <img src="@Url.Content("~" + img.FilePath)"
             style="width:200px; cursor:pointer"
             class="me-2 mb-2 border"
             onclick="previewImage('@Url.Content("~" + img.FilePath)')" />
    }
}
else
{
    <p class="text-muted">No BA images.</p>
}

<hr />


<h5 class="mt-4">After Fix Images</h5>

@{
    var afterImages = Model.FixImages?.Where(x => (x.ImageType ?? "").ToUpper() == "AFTER");
}

@if (afterImages != null && afterImages.Any())
{
    foreach (var img in afterImages)
    {
        <img src="@Url.Content("~" + img.FilePath)"
             style="width:200px; cursor:pointer"
             class="me-2 mb-2 border"
             onclick="previewImage('@Url.Content("~" + img.FilePath)')" />
    }
}
else
{
    <p class="text-muted">No after-fix images.</p>
}

<div class="mt-3">
    <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-secondary">Back</a>
</div>

<div class="modal fade" id="imagePreviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-body text-center">
                <img id="previewImage" src="" style="max-width:100%" />
            </div>
        </div>
    </div>
</div>

<script>
function previewImage(src) {
    document.getElementById('previewImage').src = src;
    var modal = new bootstrap.Modal(document.getElementById('imagePreviewModal'));
    modal.show();
}
</script>