@using System.Globalization
@model IEnumerable<ProjectTracking.Models.Project>

@{
    ViewData["Title"] = "Project List";
    var th = new CultureInfo("th-TH");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold">📁 บันทึกข้อมูลโครงการ</h2>

    <a asp-action="Create" class="btn btn-primary">
        ➕ Add Project
    </a>
</div>

<p class="text-muted">รายการโครงการทั้งหมดในระบบ</p>

<div class="row mb-3">
    <div class="col-md-5">
        <label class="form-label fw-bold">🔍 ค้นหา Project</label>
        <input type="text" id="projectSearchBox"
               class="form-control"
               placeholder="พิมพ์ชื่อโครงการ / system / database / url ..."
               autocomplete="off" />
    </div>
</div>

<div class="table-responsive project-table-wrapper">
    <table id="projectTable" class="table table-bordered table-hover align-middle project-table">
        <thead class="table-dark text-center">
            <tr>
                <th class="sticky-col-1 col-id">#</th>
                <th class="sticky-col-2 col-name">Project Name</th>
                <th class="col-ba">Business Analyst</th>
                <th class="col-system">System</th>
                <th class="col-db">Database</th>
                <th class="col-test">Test Account</th>
                <th class="col-url">Remote / URL</th>
                <th class="col-date">Start</th>
                <th class="col-date">End</th>
                <th class="col-status">Status</th>
                <th class="col-mini">Figma</th>
                <th class="col-action">Action</th>
            </tr>
        </thead>

        <tbody>
        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="12" class="text-center text-muted">— No project data —</td>
            </tr>
        }
        else
        {
            var rowNo = 1;
            foreach (var p in Model.OrderBy(x => x.EndDate ?? DateTime.MaxValue))
            {
                <tr data-ba-id="@(p.BA != null ? p.BA.EmpId.ToString() : "")">
                    <td class="sticky-col-1 col-id text-center">@rowNo</td>

                    <td class="sticky-col-2 col-name fw-semibold">
                        @p.ProjectName
                    </td>

                    <td class="col-ba text-center">
                        @(p.BA != null ? p.BA.EmpName : "-")
                    </td>

                    <td class="col-system">@p.LinkName</td>
                    <td class="col-db">@p.DatabaseName</td>
                    <td class="col-test">@p.TestAccount</td>
                    <td class="col-url small">@p.RemoteUrl</td>

                    <td class="text-center col-date">
                        @(p.StartDate?.ToString("dd MMM yyyy", th) ?? "-")
                    </td>

                    <td class="text-center col-date">
                        @(p.EndDate?.ToString("dd MMM yyyy", th) ?? "-")
                    </td>

                    <td class="text-center col-status">
                        <span class="badge
                            @(p.Status == "DONE"
                                ? "bg-success"
                                : p.Status == "IN_PROGRESS"
                                    ? "bg-info"
                                    : "bg-warning text-dark")">
                            @p.Status
                        </span>
                    </td>

                    <td class="text-center col-mini">
                        @if (!string.IsNullOrEmpty(p.FigmaLink))
                        { <a href="@p.FigmaLink" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">🎨</a> }
                        else { <span class="text-muted">-</span> }
                    </td>


                    <td class="text-center col-action">
                        <div class="d-flex justify-content-center gap-1 flex-wrap">
                            <a asp-action="Edit" asp-route-id="@p.ProjectId" class="btn btn-sm btn-outline-primary">✏️</a>
                            <a asp-controller="ProjectPhases" asp-action="Index" asp-route-projectId="@p.ProjectId" class="btn btn-sm btn-outline-info">🧩</a>
                            <a asp-controller="ProjectDocuments" 
                               asp-action="Index" 
                               asp-route-projectId="@p.ProjectId" 
                               class="btn btn-sm btn-outline-secondary">📂</a>
                            <a asp-action="Delete" asp-route-id="@p.ProjectId" class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Delete project นี้?');">🗑</a>
                        </div>
                    </td>
                </tr>
                rowNo++;
            }
        }
        </tbody>
    </table>
</div>

<style>
.project-table-wrapper{
    overflow-x:auto;
    border:1px solid #ddd;
    border-radius:10px;
}

/* ===== ปรับสัดส่วนใหม่ ===== */
.col-id{ width:60px; min-width:60px; }

/* Project name slightly smaller so other fields fit */
/* Project name column wider */
.col-name{ width:320px; min-width:320px; }

.col-ba{ width:140px; min-width:140px; }

.col-system{ width:120px; min-width:120px; }
.col-db{ width:120px; min-width:120px; }
.col-test{ width:120px; min-width:120px; }

/* URL a bit wider for readability */
/* URL column wider */
.col-url{ width:300px; min-width:300px; }

.col-date{ width:105px; min-width:105px; }
.col-status{ width:100px; min-width:100px; }
.col-mini{ width:60px; min-width:60px; }

/* Action buttons compact but not cramped */
.col-action{ width:180px; min-width:180px; }

.project-table{
    table-layout: auto;
}

/* sticky */
.sticky-col-1{
    position:sticky;
    left:0;
    background:#fff;
    z-index:3;
}

.sticky-col-2{
    position:sticky;
    left:60px;
    background:#fff;
    z-index:3;
}

thead .sticky-col-1,
thead .sticky-col-2{
    background:#212529 !important;
    color:#fff;
    z-index:4;
}

.project-table th,
.project-table td{
    vertical-align:middle;
}

/* allow text to expand horizontally instead of forcing 2 lines */
.col-name,
.col-url{
    white-space: pre-line;
    word-break: break-word;
}
</style>

@section Scripts{
<script>
document.addEventListener("DOMContentLoaded", function () {

    const searchBox = document.getElementById("projectSearchBox");

    function applyFilters(){

        const keyword = (searchBox.value || "").toLowerCase().trim();

        const rows = document.querySelectorAll("#projectTable tbody tr");

        rows.forEach(row => {

            const text = row.innerText.toLowerCase();

            const matchSearch = !keyword || text.includes(keyword);

            if(matchSearch){
                row.style.display = "";
            }else{
                row.style.display = "none";
            }
        });
    }

    searchBox.addEventListener("keyup", applyFilters);

});
</script>
}