@model ProjectTracking.Models.Project

@{
    ViewData["Title"] = "Edit Project";
}

<!-- ================= HEADER ================= -->
<div class="mb-4">
    <h2 class="fw-bold">✏️ Edit Project</h2>
    <p class="text-muted mb-0">
        แก้ไขข้อมูลโครงการ
    </p>
</div>

<!-- ================= FORM CARD ================= -->
<div class="card shadow-sm">
    <div class="card-body">

        <form asp-action="Edit"
              method="post"
              enctype="multipart/form-data"
              onsubmit="return confirm('คุณต้องการบันทึกการแก้ไข Project นี้หรือไม่?');">

            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProjectId" />

            <div class="row g-3">

                <!-- ================= BASIC INFO ================= -->

                <!-- Project Name -->
                <div class="col-md-8">
                    <label class="form-label fw-semibold">
                        📁 Project Name
                    </label>
                    <input asp-for="ProjectName"
                           class="form-control"
                           placeholder="Enter project name" />
                    <span asp-validation-for="ProjectName"
                          class="text-danger"></span>
                </div>

                <!-- Status -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        🔄 Status
                    </label>
                    <select asp-for="Status"
                            class="form-select">
                        <option value="PLAN">PLAN</option>
                        <option value="IN_PROGRESS">IN PROGRESS</option>
                        <option value="DONE">DONE</option>
                    </select>
                </div>

                <!-- Start Date -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        📅 Start Date
                    </label>
                    <input asp-for="StartDate"
                           type="date"
                           class="form-control" />
                </div>

                <!-- End Date -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        📅 End Date
                    </label>
                    <input asp-for="EndDate"
                           type="date"
                           class="form-control" />
                </div>

                <!-- ================= SYSTEM / DATABASE INFO ================= -->

                <!-- Link Name -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        🔗 ลิงค์ที่กำลังพัฒนา
                    </label>
                    <input asp-for="LinkName"
                           class="form-control"
                           placeholder="เช่น URL Website หรือ ชื่อ App" />
                </div>

                <!-- Database Name -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        🗄 ฐานข้อมูลที่ใช้
                    </label>
                    <input asp-for="DatabaseName"
                           class="form-control"
                           placeholder="เช่น implement_db" />
                </div>

                <!-- Test Account -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        🧪 ทะเบียนที่ใช้ทดสอบ
                    </label>
                    <input asp-for="TestAccount"
                           class="form-control"
                           placeholder="เช่น หน่วยงาน/ชื่อ/ทะเบียน/รหัสผ่าน" />
                </div>

                <!-- ✅ Remote (ไม่บังคับ URL) -->
                <div class="col-md-8">
                    <label class="form-label fw-semibold">
                        🌐 Remote / URL / AnyDesk / IP
                    </label>
                    <input asp-for="RemoteUrl"
                           type="text"
                           class="form-control"
                           placeholder="เช่น https://xxx | 10.10.1.20 | AnyDesk: 123 456 789" />
                    <div class="form-text">
                        ใส่เป็น URL, IP, AnyDesk, RDP หรือข้อความได้
                    </div>
                </div>

                <!-- ================= DESIGN & DOCUMENT ================= -->

                <!-- Figma Link -->
                <div class="col-md-8">
                    <label class="form-label fw-semibold">
                        🎨 Figma Link
                    </label>
                    <input asp-for="FigmaLink"
                           type="url"
                           class="form-control"
                           placeholder="https://www.figma.com/..." />
                </div>

            </div>

            <!-- ================= BUTTONS ================= -->
            <div class="mt-4 d-flex gap-2">
                <button type="submit"
                        class="btn btn-primary">
                    💾 Save Changes
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    ↩ Back
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}