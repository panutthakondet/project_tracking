@using System.Linq
@model IEnumerable<ProjectTracking.Models.Employee>

@{
    ViewData["Title"] = "Employee List";

    var menus = Context.Session.GetString("Menus") ?? "";
    var allowedMenus = menus.Split(',').Select(x => x.Trim()).ToList();

    bool HasMenu(string key)
    {
        return allowedMenus.Contains(key);
    }
}

<!-- ================= HEADER ================= -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold">👤 บันทึกข้อมูลพนักงาน</h2>
    @if (HasMenu("Employees.Create"))
    {
        <a asp-action="Create"
           class="btn btn-primary"
           title="เพิ่มพนักงาน">
            ➕ Add Employee
        </a>
    }
    else
    {
        <button class="btn btn-primary" disabled title="ไม่มีสิทธิ์เพิ่มพนักงาน">
            ➕ Add Employee
        </button>
    }
</div>

<p class="text-muted">
    รายชื่อพนักงานทั้งหมดในระบบ
</p>

<!-- ================= TABLE ================= -->
<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark text-center">
            <tr>
                <th width="80">#</th>
                <th>Name</th>
                <th>Position</th>
                <th>Email</th>
                <th width="120">Status</th>
                <th width="180">Action</th>
            </tr>
        </thead>

        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6"
                    class="text-center text-muted">
                    — No employee data —
                </td>
            </tr>
        }
        else
        {
            var row = 0;
            foreach (var emp in Model.OrderBy(e => e.Position).ThenBy(e => e.EmpId))
            {
                <tr>
                    @{ row++; }
                    <td class="text-center">@row</td>

                    <td>
                        <b>@emp.EmpName</b>
                    </td>

                    <td>
                        @emp.Position
                    </td>

                    <td>
                        @if (emp.LoginUser != null)
                        {
                            @emp.LoginUser.Email
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>

                    <td class="text-center">
                        <span class="badge
                            @(emp.Status == "ACTIVE"
                                ? "bg-success"
                                : "bg-secondary")">
                            @emp.Status
                        </span>
                    </td>

                    <td class="text-center">
                        @if (HasMenu("Employees.Edit"))
                        {
                            <a asp-action="Edit"
                               asp-route-id="@emp.EmpId"
                               class="btn btn-sm btn-outline-primary me-1"
                               title="แก้ไขพนักงาน">
                                ✏️ Edit
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-secondary me-1" disabled title="ไม่มีสิทธิ์แก้ไข">
                                ✏️ Edit
                            </button>
                        }

                        @if (HasMenu("Employees.Delete"))
                        {
                            <a asp-action="Delete"
                               asp-route-id="@emp.EmpId"
                               class="btn btn-sm btn-outline-danger"
                               title="ลบพนักงาน"
                               onclick="return confirm('ยืนยันลบพนักงานคนนี้?');">
                                🗑 Delete
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-secondary" disabled title="ไม่มีสิทธิ์ลบ">
                                🗑 Delete
                            </button>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>